@model AryamanBMS.Models.DesignationModel

<div class="module-header">

    <div>
        <h1 class="module-title">Add Designation</h1>
        <p class="module-subtitle">Create a new designation</p>
    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">
                        Designation Name
                    </label>

                    <select id="designationName"
                            asp-for="DesignationName"
                            class="app-select">

                        <option value="">Select Designation</option>

                        <option value="Software Developer">Software Developer</option>
                        <option value="Senior Software Engineer">Senior Software Engineer</option>
                        <option value="Team Lead">Team Lead</option>
                        <option value="Project Manager">Project Manager</option>
                        <option value="Business Analyst">Business Analyst</option>
                        <option value="QA Engineer">QA Engineer</option>
                        <option value="HR Executive">HR Executive</option>
                        <option value="HR Manager">HR Manager</option>
                        <option value="Accountant">Accountant</option>
                        <option value="Administrator">Administrator</option>
                        <option value="System Administrator">System Administrator</option>

                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Display Code
                    </label>

                    <input asp-for="DisplayCode"
                           id="designationCode"
                           class="app-input"
                           readonly />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Department
                    </label>

                    <select asp-for="DepartmentId"
                            class="app-select">

                        <option value="">Select Department</option>

                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.Id">
                                @department.DepartmentName
                            </option>
                        }

                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Status
                    </label>

                    <select asp-for="IsActive"
                            class="app-select">

                        <option value="true">Active</option>
                        <option value="false">Inactive</option>

                    </select>
                </div>

            </div>

            <div class="mt-4">

                <button type="submit"
                        class="btn-app btn-primary-app">
                    Save
                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

<script>
    document.getElementById("designationName")
        .addEventListener("change", function () {

            const codes = {
                "Software Developer": "SD",
                "Senior Software Engineer": "SSE",
                "Team Lead": "TL",
                "Project Manager": "PM",
                "Business Analyst": "BA",
                "QA Engineer": "QA",
                "HR Executive": "HR",
                "HR Manager": "HRM",
                "Accountant": "ACC",
                "Administrator": "ADM",
                "System Administrator": "SA"
            };

            document.getElementById("designationCode").value =
                codes[this.value] || "";
        });
</script>