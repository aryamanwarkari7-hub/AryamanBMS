@model AryamanBMS.Models.DesignationModel

<div class="module-header">

    <div>
        <h1 class="module-title">
            Delete Designation
        </h1>

        <p class="module-subtitle">
            Confirm designation deletion
        </p>
    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <p>
            Are you sure you want to delete
            <strong>@Model.DesignationName</strong> ?
        </p>

        <br />

        <div class="form-grid-2">

            <div class="form-group">
                <label class="form-label">
                    Display Code
                </label>

                <input type="text"
                       class="app-input"
                       value="@Model.DisplayCode"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">
                    Department
                </label>

                <input type="text"
                       class="app-input"
                       value="@Model.Department?.DepartmentName"
                       readonly />
            </div>

        </div>

        <br />

        <form asp-action="DeleteConfirmed" method="post">

            @Html.AntiForgeryToken()

            <input asp-for="Id" type="hidden" />

            <button type="submit"
                    class="btn-app btn-danger-app">
                Delete
            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">
                Cancel
            </a>

        </form>

    </div>

</div>