@model PagedListViewModel<DesignationModel>

@{
    ViewData["Title"] = "Designations";
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Designation Master
        </h1>

        <p class="module-subtitle">
            Manage designation records
        </p>
    </div>

    <a asp-action="Create"
       class="btn-app btn-primary-app">

        <i class="bi bi-plus-lg"></i>
        Add Designation

    </a>

</div>


<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Designation List
        </h5>

    </div>

    <div class="card-body border-bottom">

        <form asp-action="Index"
              method="get">

            <div class="d-flex flex-wrap gap-2">

                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="app-input flex-grow-1"
                       placeholder="Search designation name or code"
                       autocomplete="off" />

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Search

                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">

                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset

                </a>

            </div>

        </form>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-person-badge"></i>

                <p class="mb-0">
                    No designation records found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Designation Name</th>
                            <th>Designation Code</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var designation in Model.Items)
                        {
                            <tr>

                                <td>
                                    @designation.Id
                                </td>

                                <td>
                                    <strong>
                                        @designation.DesignationName
                                    </strong>
                                </td>

                                <td>
                                    @designation.DisplayCode
                                </td>

                                <td>
                                    @(designation.Department?.DepartmentName
                                        ?? "Not Assigned")
                                </td>

                                <td>

                                    @if (designation.IsActive)
                                    {
                                        <span class="badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Edit"
                                           asp-route-id="@designation.Id"
                                           class="btn-app btn-secondary-app btn-icon"
                                           title="Edit designation"
                                           aria-label="Edit designation">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@designation.Id"
                                           class="btn-app btn-danger-app btn-icon"
                                           title="Delete designation"
                                           aria-label="Delete designation">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>