@model AryamanBMS.Models.ProjectMeetingModel

@{
    ViewData["Title"] = "Edit Meeting";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Edit Meeting</h1>
        <p class="module-subtitle">
            Update meeting information and minutes
        </p>
    </div>

    <a asp-action="Details"
       asp-route-id="@Model.Id"
       class="btn-app btn-secondary-app">
        Back
    </a>

</div>

<form asp-action="Edit" method="post">

    @Html.AntiForgeryToken()

    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly"
         class="validation-message">
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Meeting Information</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                <input type="hidden" asp-for="ProjectId" />

                <div class="form-group">

                    <label>Project</label>

                    <input type="text"
                           class="app-input"
                           value="@Model.Project?.ProjectCode - @Model.Project?.ProjectName"
                           readonly />

                </div>

                <div class="form-group">

                    <label asp-for="MeetingTitle">
                        Meeting Title
                    </label>

                    <input asp-for="MeetingTitle"
                           class="app-input" />

                    <span asp-validation-for="MeetingTitle"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="MeetingDate">
                        Meeting Date
                    </label>

                    <span asp-validation-for="MeetingDate"
                          class="validation-message">
                    </span>

                    <input asp-for="MeetingDate"
                           type="date"
                           class="app-input" />

                </div>

                <div class="form-group">

                    <label asp-for="MeetingMode">
                        Meeting Mode
                    </label>

                    <span asp-validation-for="MeetingMode"
                          class="validation-message">
                    </span>

                    <select asp-for="MeetingMode"
                            class="app-select">

                        <option value="In Person">In Person</option>
                        <option value="Online">Online</option>
                        <option value="Hybrid">Hybrid</option>

                    </select>

                </div>

                <div class="form-group">

                    <label asp-for="StartTime">
                        Start Time
                    </label>

                    <span asp-validation-for="StartTime"
                          class="validation-message">
                    </span>

                    <input asp-for="StartTime"
                           type="time"
                           class="app-input" />

                </div>

                <div class="form-group">

                    <label asp-for="EndTime">
                        End Time
                    </label>

                    <input asp-for="EndTime"
                           type="time"
                           class="app-input" />

                    <span asp-validation-for="EndTime"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="LocationOrLink">
                        Location / Meeting Link
                    </label>

                    <input asp-for="LocationOrLink"
                           class="app-input" />

                </div>

                <div class="form-group">

                    <label asp-for="MeetingStatus">
                        Meeting Status
                    </label>

                    <span asp-validation-for="MeetingStatus"
                          class="validation-message">
                    </span>

                    <select asp-for="MeetingStatus"
                            class="app-select">

                        <option value="Scheduled">Scheduled</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>

                    </select>

                </div>

                <div class="form-group">

                    <label asp-for="NextMeetingDate">
                        Next Meeting Date
                    </label>

                    <input asp-for="NextMeetingDate"
                           type="date"
                           class="app-input" />

                    <span asp-validation-for="NextMeetingDate"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="IsActive">
                        Active Status
                    </label>

                    <select asp-for="IsActive"
                            class="app-select">

                        <option value="true">Active</option>
                        <option value="false">Inactive</option>

                    </select>

                </div>

            </div>

            <div class="form-group mt-3">

                <label asp-for="Agenda">Agenda</label>

                <textarea asp-for="Agenda"
                          rows="4"
                          class="app-textarea">
                </textarea>

                <span asp-validation-for="Agenda"
                      class="validation-message">
                </span>

            </div>

            <div class="form-group mt-3">

                <label asp-for="DiscussionSummary">
                    Discussion Summary
                </label>

                <textarea asp-for="DiscussionSummary"
                          rows="5"
                          class="app-textarea">
                </textarea>

            </div>

            <div class="form-group mt-3">

                <label asp-for="DecisionsTaken">
                    Decisions Taken
                </label>

                <textarea asp-for="DecisionsTaken"
                          rows="4"
                          class="app-textarea">
                </textarea>

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-body">

            <button type="submit"
                    class="btn-app btn-primary-app">

                <i class="bi bi-check-lg"></i>
                Update Meeting

            </button>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn-app btn-secondary-app">
                Cancel
            </a>

        </div>

    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}