@model PagedListViewModel<LeaveApplicationModel>

@{
    ViewData["Title"] = "Leave Applications";

    string selectedStatus =
        ViewBag.Status as string ?? "All";
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Leave Applications
        </h1>

        <p class="module-subtitle">
            Manage employee leave requests
        </p>
    </div>

    <a asp-action="Create"
       class="btn-app btn-primary-app">

        <i class="bi bi-plus-lg"></i>
        Apply Leave

    </a>

</div>


<div class="app-card mb-3">

    <div class="card-body">

        <form asp-action="Index"
              method="get">

            <div class="filter-form-row">

                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="app-input flex-grow-1"
                       placeholder="Application no, employee or leave type"
                       autocomplete="off" />

                <select name="status"
                        class="app-select">

                    <option value="All"
                            selected="@(selectedStatus == "All"
                                            ? "selected"
                                            : null)">
                        All Statuses
                    </option>

                    <option value="Pending"
                            selected="@(selectedStatus == "Pending"
                                            ? "selected"
                                            : null)">
                        Pending
                    </option>

                    <option value="Approved"
                            selected="@(selectedStatus == "Approved"
                                            ? "selected"
                                            : null)">
                        Approved
                    </option>

                    <option value="Rejected"
                            selected="@(selectedStatus == "Rejected"
                                            ? "selected"
                                            : null)">
                        Rejected
                    </option>

                    <option value="Cancelled"
                            selected="@(selectedStatus == "Cancelled"
                                            ? "selected"
                                            : null)">
                        Cancelled
                    </option>

                </select>

                <div class="filter-form-actions">
                    <button type="submit"
                            class="btn-app btn-primary-app">
                        <i class="bi bi-search"></i>
                        Search
                    </button>

                    <a asp-action="Index"
                       class="btn-app btn-secondary-app">
                        <i class="bi bi-arrow-counterclockwise"></i>
                        Reset
                    </a>
                </div>

            </div>

        </form>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Leave Application List
        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-calendar-x"></i>

                <p class="mb-0">
                    No leave applications found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Application No</th>
                            <th>Employee</th>
                            <th>Leave Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Days</th>
                            <th>Status</th>
                            <th>Cancellation</th>
                            <th>Applied On</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.Items)
                        {
                            <tr>

                                <td>
                                    <strong>
                                        @item.ApplicationNumber
                                    </strong>
                                </td>

                                <td>
                                    @(item.Employee?.FullName ?? "-")

                                    <br />

                                    <small>
                                        @(item.Employee?.EmployeeCode ?? "-")
                                    </small>
                                </td>

                                <td>
                                    @(item.LeaveType?.LeaveName ?? "-")
                                </td>

                                <td>
                                    @(item.FromDate.ToString("dd-MMM-yyyy"))
                                </td>

                                <td>
                                    @(item.ToDate.ToString("dd-MMM-yyyy"))
                                </td>

                                <td>
                                    @item.NumberOfDays
                                </td>

                                <td>

                                    @switch (item.Status)
                                    {
                                        case "Pending":
                                            <span class="badge-warning">
                                                Pending
                                            </span>
                                            break;

                                        case "Approved":
                                            <span class="badge-success">
                                                Approved
                                            </span>
                                            break;

                                        case "Rejected":
                                            <span class="badge-danger">
                                                Rejected
                                            </span>
                                            break;

                                        case "Cancelled":
                                            <span class="badge-secondary">
                                                Cancelled
                                            </span>
                                            break;

                                        default:
                                            <span>
                                                @item.Status
                                            </span>
                                            break;
                                    }

                                </td>
                                <td>
                                    @if (string.IsNullOrWhiteSpace(item.CancellationStatus))
                                    {
                                        <span>-</span>
                                    }
                                    else
                                    {
                                        switch (item.CancellationStatus)
                                        {
                                            case "Pending":
                                                <span class="badge-warning">
                                                    Pending
                                                </span>
                                                break;

                                            case "Approved":
                                                <span class="badge-success">
                                                    Approved
                                                </span>
                                                break;

                                            case "Rejected":
                                                <span class="badge-danger">
                                                    Rejected
                                                </span>
                                                break;

                                            default:
                                                <span>
                                                    @item.CancellationStatus
                                                </span>
                                                break;
                                        }
                                    }
                                </td>

                                <td>
                                    @(item.AppliedOn.ToString("dd-MMM-yyyy"))
                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn-app btn-primary-app btn-icon"
                                           title="View details"
                                           aria-label="View leave details">

                                            <i class="bi bi-eye"></i>

                                        </a>
                                        @if (item.Status == "Approved" &&
                                                                        item.CancellationStatus != "Pending" &&
                                                                        item.CancellationStatus != "Approved" &&
                                                                        !User.IsInRole("Admin") &&
                                                                        !User.IsInRole("HR"))
                                        {
                                            <button type="button"
                                                    class="btn-app btn-secondary-app btn-icon"
                                                    title="Request cancellation"
                                                    aria-label="Request cancellation"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#requestCancellationModal-@item.Id">

                                                <i class="bi bi-arrow-counterclockwise"></i>

                                            </button>
                                        }

                                        @if (item.Status == "Pending")
                                        {
                                            @if (User.IsInRole("Admin") ||
                                                 User.IsInRole("HR"))
                                            {
                                                <form asp-action="Approve"
                                                      method="post"
                                                      class="d-inline">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn-app btn-success-app btn-icon"
                                                            title="Approve"
                                                            aria-label="Approve leave"
                                                            onclick="return confirm('Approve this leave application?');">

                                                        <i class="bi bi-check-lg"></i>

                                                    </button>

                                                </form>

                                                <form asp-action="Reject"
                                                      method="post"
                                                      class="d-inline">

                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden"
                                                           name="id"
                                                           value="@item.Id" />

                                                    <button type="submit"
                                                            class="btn-app btn-danger-app btn-icon"
                                                            title="Reject"
                                                            aria-label="Reject leave"
                                                            onclick="return confirm('Reject this leave application?');">

                                                        <i class="bi bi-x-lg"></i>

                                                    </button>

                                                </form>
                                            }

                                            <form asp-action="Cancel"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@item.Id" />

                                                <button type="submit"
                                                        class="btn-app btn-secondary-app btn-icon"
                                                        title="Cancel"
                                                        aria-label="Cancel leave"
                                                        onclick="return confirm('Cancel this leave application?');">

                                                    <i class="bi bi-slash-circle"></i>

                                                </button>

                                            </form>
                                        }

                                        @if ((User.IsInRole("Admin") || User.IsInRole("HR")) &&
                                                                        item.Status == "Approved" &&
                                                                        item.CancellationStatus == "Pending")
                                        {
                                            <button type="button"
                                                    class="btn-app btn-success-app btn-icon"
                                                    title="Approve cancellation"
                                                    aria-label="Approve cancellation"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#approveCancellationModal-@item.Id">

                                                <i class="bi bi-check-circle"></i>

                                            </button>

                                            <button type="button"
                                                    class="btn-app btn-danger-app btn-icon"
                                                    title="Reject cancellation"
                                                    aria-label="Reject cancellation"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#rejectCancellationModal-@item.Id">

                                                <i class="bi bi-x-circle"></i>

                                            </button>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

                @foreach (var item in Model.Items)
                {
                    @if (item.Status == "Approved" &&
                                item.CancellationStatus != "Pending" &&
                                item.CancellationStatus != "Approved" &&
                                !User.IsInRole("Admin") &&
                                !User.IsInRole("HR"))
                    {
                        <div class="modal fade"
                             id="requestCancellationModal-@item.Id"
                             tabindex="-1"
                             aria-hidden="true">

                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">

                                    <form asp-action="RequestCancellation"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />

                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                Request Leave Cancellation
                                            </h5>

                                            <button type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal">
                                            </button>
                                        </div>

                                        <div class="modal-body">

                                            <p>
                                                Request cancellation for
                                                <strong>
                                                    @item.ApplicationNumber
                                                </strong>
                                            </p>

                                            <label class="form-label">
                                                Cancellation Reason
                                            </label>

                                            <textarea name="cancellationReason"
                                          class="app-input"
                                          rows="4"
                                          maxlength="500"
                                          required></textarea>

                                        </div>

                                        <div class="modal-footer">

                                            <button type="button"
                                                    class="btn-app btn-secondary-app"
                                                    data-bs-dismiss="modal">
                                                Close
                                            </button>

                                            <button type="submit"
                                                    class="btn-app btn-primary-app">
                                                Submit Request
                                            </button>

                                        </div>

                                    </form>

                                </div>
                            </div>
                        </div>
                    }

                    @if ((User.IsInRole("Admin") || User.IsInRole("HR")) &&
                                item.Status == "Approved" &&
                                item.CancellationStatus == "Pending")
                    {
                        <div class="modal fade"
                             id="approveCancellationModal-@item.Id"
                             tabindex="-1"
                             aria-hidden="true">

                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">

                                    <form asp-action="ApproveCancellation"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />

                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                Approve Cancellation
                                            </h5>

                                            <button type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal">
                                            </button>
                                        </div>

                                        <div class="modal-body">

                                            <p>
                                                Application:
                                                <strong>
                                                    @item.ApplicationNumber
                                                </strong>
                                            </p>

                                            <p>
                                                Employee reason:
                                                <strong>
                                                    @(item.CancellationReason ?? "-")
                                                </strong>
                                            </p>

                                            <label class="form-label">
                                                Review Remarks
                                            </label>

                                            <textarea name="cancellationRemarks"
                                          class="app-input"
                                          rows="3"
                                          maxlength="500"></textarea>

                                        </div>

                                        <div class="modal-footer">

                                            <button type="button"
                                                    class="btn-app btn-secondary-app"
                                                    data-bs-dismiss="modal">
                                                Close
                                            </button>

                                            <button type="submit"
                                                    class="btn-app btn-success-app">
                                                Approve Cancellation
                                            </button>

                                        </div>

                                    </form>

                                </div>
                            </div>
                        </div>

                        <div class="modal fade"
                             id="rejectCancellationModal-@item.Id"
                             tabindex="-1"
                             aria-hidden="true">

                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">

                                    <form asp-action="RejectCancellation"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@item.Id" />

                                        <div class="modal-header">
                                            <h5 class="modal-title">
                                                Reject Cancellation
                                            </h5>

                                            <button type="button"
                                                    class="btn-close"
                                                    data-bs-dismiss="modal">
                                            </button>
                                        </div>

                                        <div class="modal-body">

                                            <p>
                                                Application:
                                                <strong>
                                                    @item.ApplicationNumber
                                                </strong>
                                            </p>

                                            <p>
                                                Employee reason:
                                                <strong>
                                                    @(item.CancellationReason ?? "-")
                                                </strong>
                                            </p>

                                            <label class="form-label">
                                                Rejection Remarks
                                            </label>

                                            <textarea name="cancellationRemarks"
                                          class="app-input"
                                          rows="3"
                                          maxlength="500"
                                          required></textarea>

                                        </div>

                                        <div class="modal-footer">

                                            <button type="button"
                                                    class="btn-app btn-secondary-app"
                                                    data-bs-dismiss="modal">
                                                Close
                                            </button>

                                            <button type="submit"
                                                    class="btn-app btn-danger-app">
                                                Reject Cancellation
                                            </button>

                                        </div>

                                    </form>

                                </div>
                            </div>
                        </div>
                    }
                }

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>