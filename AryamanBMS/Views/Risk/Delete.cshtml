@model AryamanBMS.Models.ProjectRiskModel

@{
    ViewData["Title"] = "Delete Project Risk";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Delete Project Risk</h1>
        <p class="module-subtitle">
            Confirm risk deletion
        </p>
    </div>

    <a asp-action="Details"
       asp-route-id="@Model.Id"
       class="btn-app btn-secondary-app">
        Back
    </a>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Risk Information</h5>
    </div>

    <div class="card-body">

        <div class="alert alert-danger">
            Are you sure you want to permanently delete this project risk?
        </div>

        <table class="app-table">

            <tbody>

                <tr>
                    <th>Project</th>
                    <td>
                        @Model.Project?.ProjectCode -
                        @Model.Project?.ProjectName
                    </td>
                </tr>

                <tr>
                    <th>Risk</th>
                    <td>@Model.RiskTitle</td>
                </tr>

                <tr>
                    <th>Category</th>
                    <td>@Model.RiskCategory</td>
                </tr>

                <tr>
                    <th>Owner</th>
                    <td>
                        @(Model.RiskOwnerEmployee?.FullName
                                                ?? "Not Assigned")
                    </td>
                </tr>

                <tr>
                    <th>Score</th>
                    <td>
                        @Model.RiskScore -
                        @Model.Severity
                    </td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>@Model.RiskStatus</td>
                </tr>

            </tbody>

        </table>

    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <form asp-action="Delete"
              asp-route-id="@Model.Id"
              method="post">

            @Html.AntiForgeryToken()

            <button type="submit"
                    class="btn-app btn-danger-app">

                <i class="bi bi-trash"></i>
                Delete Risk

            </button>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn-app btn-secondary-app">
                Cancel
            </a>

        </form>

    </div>

</div>