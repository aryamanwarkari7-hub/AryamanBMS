@model PagedListViewModel<LeaveBalanceModel>

@{
    ViewData["Title"] = "Leave Balance";

    int selectedYear = (int)ViewBag.Year;
    int selectedEmployeeId = (int)ViewBag.EmployeeId;
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Leave Balance
        </h1>

        <p class="module-subtitle">
            Employee-wise yearly leave balance
        </p>
    </div>

</div>


<div class="app-card mb-3">

    <div class="card-header">

        <h5 class="card-title">
            Leave Balance Filter
        </h5>

    </div>

    <div class="card-body">

        <div class="d-flex justify-content-between
            align-items-end flex-wrap gap-3">

            <form asp-action="Index"
                  method="get"
                  class="d-flex align-items-end gap-2 flex-wrap">

                <div>

                    <label class="form-label"
                           for="year">
                        Year
                    </label>

                    <select id="year"
                            name="year"
                            class="app-select">

                        @for (int y = DateTime.Today.Year - 2;
                             y <= DateTime.Today.Year + 2;
                             y++)
                        {
                            if (y == selectedYear)
                            {
                                <option value="@y"
                                        selected>
                                    @y
                                </option>
                            }
                            else
                            {
                                <option value="@y">
                                    @y
                                </option>
                            }
                        }

                    </select>

                </div>

                <div>

                    <label class="form-label"
                           for="employeeId">
                        Employee
                    </label>

                    <select id="employeeId"
                            name="employeeId"
                            class="app-select">

                        @if (selectedEmployeeId == 0)
                        {
                            <option value="0"
                                    selected>
                                All Employees
                            </option>
                        }
                        else
                        {
                            <option value="0">
                                All Employees
                            </option>
                        }

                        @foreach (var employee in ViewBag.Employees)
                        {
                            if (employee.Id == selectedEmployeeId)
                            {
                                <option value="@employee.Id"
                                        selected>
                                    @employee.EmployeeCode -
                                    @employee.FullName
                                </option>
                            }
                            else
                            {
                                <option value="@employee.Id">
                                    @employee.EmployeeCode -
                                    @employee.FullName
                                </option>
                            }
                        }

                    </select>

                </div>

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Load

                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">

                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset

                </a>

            </form>

            <div class="d-flex gap-2 flex-wrap">

                <form asp-action="Generate"
                      method="post">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="year"
                           value="@selectedYear" />

                    <button type="submit"
                            class="btn-app btn-success-app"
                            onclick="return confirm('Generate leave balance for selected year?');">

                        <i class="bi bi-plus-circle"></i>
                        Generate Balance

                    </button>

                </form>

                <a asp-action="Export"
                   asp-route-year="@selectedYear"
                   asp-route-employeeId="@selectedEmployeeId"
                   class="btn-app btn-success-app">

                    <i class="bi bi-file-earmark-excel"></i>
                    Export Excel

                </a>

            </div>

        </div>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Leave Balance Register - @selectedYear
        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-calendar-x"></i>

                <p class="mb-0">
                    No leave balance records found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Employee Code</th>
                            <th>Employee</th>
                            <th>Leave Type</th>
                            <th>Current Allocation</th>
                            <th>Carry Forward</th>
                            <th>Total Allocated</th>
                            <th>Used</th>
                            <th>Balance</th>
                            @* <th>Year</th> *@
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model.Items)
                        {
                            <tr>

                                <td>
                                    @(item.Employee?.EmployeeCode ?? "-")
                                </td>

                                <td>
                                    @(item.Employee?.FullName ?? "-")
                                </td>

                                <td>
                                    @(item.LeaveType?.LeaveCode ?? "-")
                                    -
                                    @(item.LeaveType?.LeaveName ?? "-")
                                </td>

                                <td>
                                    @item.CurrentYearAllocation.ToString("0.##")
                                </td>

                                <td>
                                    @item.CarryForwardDays.ToString("0.##")
                                </td>

                                <td>
                                    @item.AllocatedDays.ToString("0.##")
                                </td>

                                <td>
                                    @item.UsedDays.ToString("0.##")
                                </td>

                                <td>
                                    <strong>
                                        @item.BalanceDays.ToString("0.##")
                                    </strong>
                                </td>

                                @* <td>
                                    @item.LeaveYear
                                </td> *@

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>