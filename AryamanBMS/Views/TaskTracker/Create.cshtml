@model AryamanBMS.Models.ProjectTaskProgressModel

@using AryamanBMS.Models

@{
    ViewData["Title"] = "Add Task Update";

    var tasks =
        ViewBag.Tasks as IEnumerable<ProjectTaskModel>
        ?? Enumerable.Empty<ProjectTaskModel>();

        var projects =
    ViewBag.Projects as IEnumerable<ProjectModel>
    ?? Enumerable.Empty<ProjectModel>();

    int? routeProjectId =
    ViewBag.ProjectId == null
        ? null
        : Convert.ToInt32(ViewBag.ProjectId);
}

<div class="module-header">

    <div>
        <h1 class="module-title">Add Task Update</h1>

        <p class="module-subtitle">
            Record work completed for a project task
        </p>
    </div>

    <a asp-action="Index"
       asp-route-projectId="@routeProjectId"
       class="btn-app btn-secondary-app">

        Back

    </a>

</div>

<form asp-action="Create"
      asp-route-projectId="@routeProjectId"
      method="post">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="validation-message">
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Task Update Information</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                @if (Model.ProjectTaskId == 0)
                {
                    <div class="form-group">
                        <label>Project</label>

                        <select id="taskUpdateProjectSelect"
                                class="app-select">
                            <option value="">Select Project</option>

                            @foreach (var project in projects)
                            {
                                <option value="@project.Id"
                                        selected="@(routeProjectId == project.Id)">
                                    @project.ProjectCode - @project.ProjectName
                                </option>
                            }
                        </select>
                    </div>
                }

                <div class="form-group">

                    <label asp-for="ProjectTaskId">
                        Project Task
                    </label>

                    <select asp-for="ProjectTaskId"
                            id="taskUpdateTaskSelect"
                            class="app-select"
                            disabled="@(Model.ProjectTaskId == 0 && routeProjectId == null)">

                        <option value="">
                            @(routeProjectId == null ? "Select Project First" : "Select Project Task")
                        </option>

                        @foreach (var task in tasks)
                        {
                            <option value="@task.Id">

                                @task.Project?.ProjectCode -
                                @task.TaskCode -
                                @task.TaskTitle

                            </option>
                        }

                    </select>

                    <span asp-validation-for="ProjectTaskId"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="ProgressDate">
                        Update Date
                    </label>

                    <input asp-for="ProgressDate"
                           type="date"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")"
                           class="app-input" />

                    <span asp-validation-for="ProgressDate"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="HoursWorked">
                        Hours Worked
                    </label>

                    <input asp-for="HoursWorked"
                           type="number"
                           min="0"
                           max="24"
                           step="0.25"
                           class="app-input"
                           placeholder="Example: 4.50" />

                    <span asp-validation-for="HoursWorked"
                          class="validation-message">
                    </span>

                </div>

                <div class="form-group">

                    <label asp-for="CompletionPercentage">
                        Task Completion %
                    </label>

                    <input asp-for="CompletionPercentage"
                           type="number"
                           min="0"
                           max="100"
                           class="app-input"
                           placeholder="0 to 100" />

                    <span asp-validation-for="CompletionPercentage"
                          class="validation-message">
                    </span>

                </div>

            </div>

            <div class="form-group mt-3">

                <label asp-for="ProgressNotes">
                    Update Notes
                </label>

                <textarea asp-for="ProgressNotes"
                          rows="5"
                          class="app-textarea"
                          placeholder="Describe the work completed, issues found, or next steps">
                </textarea>

                <span asp-validation-for="ProgressNotes"
                      class="validation-message">
                </span>

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-body">

            <button type="submit"
                    class="btn-app btn-primary-app">

                <i class="bi bi-check-lg"></i>
                Save Update

            </button>

            <a asp-action="Index"
               asp-route-projectId="@routeProjectId"
               class="btn-app btn-danger-app">

                Cancel

            </a>

        </div>

    </div>

</form>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/task-tracker.js" asp-append-version="true"></script>

}