@model AryamanBMS.Models.ProjectTaskProgressModel

@{
    ViewData["Title"] = "Task Update Details";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Task Update Details</h1>

        <p class="module-subtitle">
            View recorded task update information
        </p>
    </div>

    <div class="d-flex gap-2">

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn-app btn-primary-app">

            <i class="bi bi-pencil"></i>
            Edit

        </a>

        <a asp-action="Index"
           asp-route-projectTaskId="@Model.ProjectTaskId"
           class="btn-app btn-secondary-app">

            Back

        </a>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Task Update Information</h5>
    </div>

    <div class="card-body">

        <table class="app-table">

            <tbody>

                <tr>
                    <th>Project</th>
                    <td>
                        @Model.ProjectTask?.Project?.ProjectCode -
                        @Model.ProjectTask?.Project?.ProjectName
                    </td>
                </tr>

                <tr>
                    <th>Task</th>
                    <td>
                        @Model.ProjectTask?.TaskCode -
                        @Model.ProjectTask?.TaskTitle
                    </td>
                </tr>

                <tr>
                    <th>Update Date</th>
                    <td>
                        @Model.ProgressDate.ToString("dd-MM-yyyy")
                    </td>
                </tr>

                <tr>
                    <th>Hours Worked</th>
                    <td>
                        @Model.HoursWorked.ToString("0.00")
                    </td>
                </tr>

                <tr>
                    <th>Task Completion %</th>
                    <td>
                        <strong>
                            @Model.CompletionPercentage%
                        </strong>

                        <div class="progress mt-2"
                             style="height: 8px; max-width: 350px;">

                            <div class="progress-bar"
                                 role="progressbar"
                                 style="width: @Model.CompletionPercentage%;"
                                 aria-valuenow="@Model.CompletionPercentage"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>

                        </div>
                    </td>
                </tr>

                <tr>
                    <th>Active Status</th>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="status-badge status-active">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">
                                Inactive
                            </span>
                        }
                    </td>
                </tr>

                <tr>
                    <th>Created On</th>
                    <td>
                        @Model.CreatedOn.ToString("dd-MM-yyyy hh:mm tt")
                    </td>
                </tr>

                <tr>
                    <th>Updated On</th>
                    <td>
                        @(Model.UpdatedOn?.ToString("dd-MM-yyyy hh:mm tt") ?? "-")
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Update Notes</h5>
    </div>

    <div class="card-body">

        <p class="mb-0">
            @Model.ProgressNotes
        </p>

    </div>

</div>
