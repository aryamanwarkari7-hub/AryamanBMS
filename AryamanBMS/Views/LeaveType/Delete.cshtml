@model AryamanBMS.Models.LeaveTypeModel

@{
    ViewData["Title"] = "Deactivate Leave Type";
}

<div class="module-header">

    <div>

        <h1 class="module-title">
            Deactivate Leave Type
        </h1>

        <p class="module-subtitle">
            Confirm deletion
        </p>

    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <p>

            Are you sure you want to deactivate this leave type?

            <strong>
                @Model.LeaveName
            </strong>?

        </p>

        <form asp-action="DeleteConfirmed">

            <input asp-for="Id"
                   type="hidden" />

            <button type="submit"
                    class="btn-app btn-danger-app">
                Deactivate
            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">

                Cancel

            </a>

        </form>

    </div>

</div>