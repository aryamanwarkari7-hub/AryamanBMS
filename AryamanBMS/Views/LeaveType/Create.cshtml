@model AryamanBMS.Models.LeaveTypeModel

@{
    ViewData["Title"] = "Create Leave Type";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Create Leave Type</h1>
        <p class="module-subtitle">
            Add a new leave type
        </p>
    </div>

</div>

<form asp-action="Create">

    <div class="app-card">

        <div class="card-body">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="form-group mb-3">

                <label asp-for="LeaveCode"
                       class="form-label">
                </label>

                <input asp-for="LeaveCode"
                       class="app-input" />

                <span asp-validation-for="LeaveCode"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="LeaveName"
                       class="form-label">
                </label>

                <input asp-for="LeaveName"
                       class="app-input" />

            </div>

            <div class="form-group mb-3">

                <label asp-for="DaysPerYear"
                       class="form-label">
                </label>

                <input asp-for="DaysPerYear"
                       class="app-input" />

            </div>

            <div class="form-check mb-2">

                <input asp-for="IsCarryForward"
                       class="form-check-input" />

                <label asp-for="IsCarryForward"
                       class="form-check-label">
                </label>

            </div>

            <div class="form-group mb-3"
                 id="maximumCarryForwardGroup">

                <label asp-for="MaximumCarryForwardDays"
                       class="form-label">
                </label>

                <input asp-for="MaximumCarryForwardDays"
                       type="number"
                       min="0"
                       step="1"
                       class="app-input"
                       placeholder="Enter maximum carry-forward days" />

                <span asp-validation-for="MaximumCarryForwardDays"
                      class="text-danger">
                </span>

                <small class="text-muted">
                    Used only when Carry Forward is enabled.
                </small>

            </div>

            <div class="form-check mb-2">

                <input asp-for="IsPaidLeave"
                       class="form-check-input" />

                <label asp-for="IsPaidLeave"
                       class="form-check-label">
                    Paid Leave
                </label>

            </div>

            <div class="form-check mb-4">

                <input asp-for="IsActive"
                       class="form-check-input" />

                <label asp-for="IsActive"
                       class="form-check-label">
                </label>

            </div>

            <button type="submit"
                    class="btn-app btn-primary-app">

                Save

            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">

                Cancel

            </a>

        </div>

    </div>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const checkbox =
                document.getElementById("IsCarryForward");

            const group =
                document.getElementById("maximumCarryForwardGroup");

            const input =
                document.getElementById("MaximumCarryForwardDays");

            function toggleMaximumCarryForward() {

                const enabled = checkbox.checked;

                group.style.display =
                    enabled ? "block" : "none";

                if (!enabled) {
                    input.value = "0";
                }
            }

            checkbox.addEventListener(
                "change",
                toggleMaximumCarryForward);

            toggleMaximumCarryForward();
        });
    </script>
}