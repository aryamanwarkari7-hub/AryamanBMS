@model AryamanBMS.Models.LeaveTypeModel

@{
    ViewData["Title"] = "Edit Leave Type";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Edit Leave Type</h1>
        <p class="module-subtitle">
            Edit leave type
        </p>
    </div>

</div>

<form asp-action="Create">
    <input asp-for="Id" type="hidden" />

    <div class="app-card">

        <div class="card-body">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="form-group mb-3">

                <label asp-for="LeaveCode"
                       class="form-label">
                </label>

                <input asp-for="LeaveCode"
                       class="app-input" />

                <span asp-validation-for="LeaveCode"
                      class="text-danger">
                </span>

            </div>

            <div class="form-group mb-3">

                <label asp-for="LeaveName"
                       class="form-label">
                </label>

                <input asp-for="LeaveName"
                       class="app-input" />

            </div>

            <div class="form-group mb-3">

                <label asp-for="DaysPerYear"
                       class="form-label">
                </label>

                <input asp-for="DaysPerYear"
                       class="app-input" />

            </div>

            <div class="form-check mb-2">

                <input asp-for="IsCarryForward"
                       class="form-check-input" />

                <label asp-for="IsCarryForward"
                       class="form-check-label">
                </label>

            </div>
            <div class="form-check mb-2">

                <input asp-for="IsPaidLeave"
                       class="form-check-input" />

                <label asp-for="IsPaidLeave"
                       class="form-check-label">
                    Paid Leave
                </label>

            </div>

            <div class="form-check mb-4">

                <input asp-for="IsActive"
                       class="form-check-input" />

                <label asp-for="IsActive"
                       class="form-check-label">
                </label>

            </div>

            <button type="submit"
                    class="btn-app btn-primary-app">

                Save

            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">

                Cancel

            </a>

        </div>

    </div>

</form>