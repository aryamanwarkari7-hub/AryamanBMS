@model AryamanBMS.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="module-header">

    <div>
        <h2>Change Password</h2>
        <p>Update your account password</p>
    </div>

</div>

<div class="app-card p-4">

    <form asp-action="ChangePassword">

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="mb-3">

            <label class="form-label">
                Current Password
            </label>

            <input asp-for="CurrentPassword"
                   type="password"
                   class="app-input" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                New Password
            </label>

            <input asp-for="NewPassword"
                   type="password"
                   class="app-input" />

        </div>

        <div class="mb-3">

            <label class="form-label">
                Confirm Password
            </label>

            <input asp-for="ConfirmPassword"
                   type="password"
                   class="app-input" />

        </div>

        <button type="submit"
                class="btn-app btn-primary-app">

            Change Password

        </button>

    </form>

</div>