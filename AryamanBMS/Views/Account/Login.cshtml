@model AryamanBMS.ViewModels.LoginViewModel

@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="auth-page corporate-login">

    <section class="login-brand-panel">

        <div class="login-brand-content">

            <div class="login-logo-wrap">
                <img src="~/images/aryaman_logo.svg"
                     asp-append-version="true"
                     alt="Aryaman Technologies Private Limited"
                     class="login-logo" />
            </div>

            <div>
                <p class="login-eyebrow">
                    Aryaman Technologies Private Limited
                </p>

                <h1>
                    Business Management System
                </h1>

                <p class="login-copy">
                    Secure access for HR, payroll, attendance, employee records,
                    projects and business operations.
                </p>
            </div>

            <div class="login-highlights">

                <div>
                    <i class="bi bi-shield-check"></i>
                    <span>Role-based access</span>
                </div>

                <div>
                    <i class="bi bi-people"></i>
                    <span>Employee lifecycle</span>
                </div>

                <div>
                    <i class="bi bi-graph-up-arrow"></i>
                    <span>Operational visibility</span>
                </div>

            </div>

        </div>

    </section>

    <section class="login-form-panel">

        <div class="login-card">

            <div class="login-card-header">

                <p class="login-card-kicker">
                    Secure sign in
                </p>

                <h2>
                    Welcome back
                </h2>

                <p>
                    Enter your credentials to continue to Aryaman BMS.
                </p>

            </div>

            <form asp-action="Login"
                  method="post"
                  class="login-form">

                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly"
                     class="app-alert-danger">
                </div>

                <div class="form-group">

                    <label asp-for="UserName"
                           class="form-label">
                        Username
                    </label>

                    <input asp-for="UserName"
                           class="app-input"
                           autocomplete="username"
                           placeholder="Enter username" />

                    <span asp-validation-for="UserName"
                          class="validation-message"></span>

                </div>

                <div class="form-group">

                    <label asp-for="Password"
                           class="form-label">
                        Password
                    </label>

                    <input asp-for="Password"
                           class="app-input"
                           autocomplete="current-password"
                           placeholder="Enter password" />

                    <span asp-validation-for="Password"
                          class="validation-message"></span>

                </div>

                <div class="login-form-options">

                    <label class="form-check">

                        <input asp-for="RememberMe"
                               class="form-check-input" />

                        <span class="form-check-label">
                            Remember me
                        </span>

                    </label>

                </div>

                <button type="submit"
                        class="btn-app btn-primary-app login-submit">
                    <i class="bi bi-box-arrow-in-right"></i>
                    Sign in
                </button>

            </form>

            <p class="login-support">
                Need access? Contact your system administrator.
            </p>

        </div>

    </section>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}