@model IEnumerable<AryamanBMS.Models.ProjectMemberModel>
@using AryamanBMS.Models

@{
    ViewData["Title"] = "Project Members";

    var projects =
        ViewBag.Projects as IEnumerable<ProjectModel>
        ?? Enumerable.Empty<ProjectModel>();

    int? selectedProjectId = ViewBag.ProjectId as int?;

    var selectedProject =
        projects.FirstOrDefault(p =>
            selectedProjectId.HasValue &&
            p.Id == selectedProjectId.Value);
}

<div class="module-header">

    <div>
        <h1 class="module-title">Project Members</h1>

        <p class="module-subtitle">
            @if (selectedProject != null)
            {
                <span>
                    @selectedProject.ProjectCode -
                    @selectedProject.ProjectName
                </span>
            }
            else
            {
                <span>
                    View employee assignments across all projects
                </span>
            }
        </p>
    </div>

    <div class="d-flex gap-2">

        @if (selectedProjectId.HasValue)
        {
            <a asp-action="Add"
               asp-route-projectId="@selectedProjectId"
               class="btn-app btn-primary-app">

                <i class="bi bi-person-plus"></i>
                Add Member

            </a>

            <a asp-controller="Project"
               asp-action="Details"
               asp-route-id="@selectedProjectId"
               class="btn-app btn-secondary-app">

                Back to Project

            </a>
        }
        else
        {
            <button type="button"
                    class="btn-app btn-primary-app"
                    disabled
                    title="Select a project first">

                <i class="bi bi-person-plus"></i>
                Select Project to Add Member

            </button>
        }

    </div>

</div>

@* @if (TempData["Success"] != null)
{
    <div class="app-alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
