@model IEnumerable<AryamanBMS.Models.ProjectMemberModel>

@{
    ViewData["Title"] = "Project Members";
}

<div class="module-header">
    <div>
        <h1 class="module-title">Project Members</h1>
        <p class="module-subtitle">
            View employee assignments across all projects
        </p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="app-alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="app-card">
    <div class="card-body">

        <form method="get" asp-action="AllMembers">

            <div class="form-grid-2">

                <div class="form-group">
                    <label>Project</label>

                    <select name="projectId"
                            class="app-select">

                        <option value="">All Projects</option>

                        @foreach (var project in ViewBag.Projects)
                        {
                            <option value="@project.Id"
                                    selected="@(ViewBag.ProjectId == project.Id)">
                                @project.ProjectCode - @project.ProjectName
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Search</label>

                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"
                           class="app-input"
                           placeholder="Employee, role or project" />
                </div>

            </div>

            <div class="mt-3">
                <button type="submit"
                        class="btn-app btn-primary-app">
                    Filter
                </button>

                <a asp-action="AllMembers"
                   class="btn-app btn-secondary-app">
                    Reset
                </a>
            </div>

        </form>

    </div>
</div>

<div class="app-card table-card">
    <div class="card-header">
        <h5 class="card-title">Member Assignments</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Employee Code</th>
                    <th>Employee Name</th>
                    <th>Department</th>
                    <th>Designation</th>
                    <th>Project Role</th>
                    <th>Assigned On</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var member in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Project"
                                   asp-action="Details"
                                   asp-route-id="@member.ProjectId">
                                    @member.Project?.ProjectCode
                                </a>
                            </td>

                            <td>
                                @member.Employee?.EmployeeCode
                            </td>

                            <td>
                                @member.Employee?.FullName
                            </td>

                            <td>
                                @(member.Employee?.Department?.DepartmentName ?? "-")
                            </td>

                            <td>
                                @(member.Employee?.Designation?.DesignationName ?? "-")
                            </td>

                            <td>
                                @(member.RoleInProject ?? "-")
                            </td>

                            <td>
                                @member.AssignedOn.ToString("dd-MM-yyyy")
                            </td>

                            <td>
                                @if (member.IsActive)
                                {
                                    <span class="status-badge status-active">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="action-buttons d-flex d-row gap-1">

                                    <a asp-action="Index"
                                       asp-route-projectId="@member.ProjectId"
                                       class="btn-icon btn-primary-app btn-view"
                                       title="View Project Members">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-controller="Employee"
                                       asp-action="Details"
                                       asp-route-id="@member.EmployeeId"
                                       class="btn-icon btn-secondary-app btn-icon"
                                       title="View Employee">
                                        <i class="bi bi-person"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9"
                            class="text-center text-muted">
                            No project members found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <div class="pagination-container">

        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a asp-action="AllMembers"
               asp-route-page="@i"
               asp-route-projectId="@ViewBag.ProjectId"
               asp-route-searchText="@ViewBag.SearchText"
               class="page-link-app @(i == ViewBag.CurrentPage ? "active" : "")">
                @i
            </a>
        }

    </div>
}