@model IEnumerable<AryamanBMS.Models.ProjectMemberModel>

@{
    ViewData["Title"] = "Project Members";
    var project = ViewBag.Project as AryamanBMS.Models.ProjectModel;
}

<div class="module-header">
    <div>
        <h1 class="module-title">Project Members</h1>
        <p class="module-subtitle">
            @(project != null
                        ? $"{project.ProjectCode} - {project.ProjectName}"
                        : "Manage assigned project members")
        </p>
    </div>

    <div class="d-flex gap-2">
        <a asp-action="Add"
           asp-route-projectId="@project?.Id"
           class="btn-app btn-primary-app">
            <i class="bi bi-person-plus"></i>
            Add Member
        </a>

        <a asp-controller="Project"
           asp-action="Details"
           asp-route-id="@project?.Id"
           class="btn-app btn-secondary-app">
            Back
        </a>
    </div>
</div>

