@model AryamanBMS.Models.ProjectMemberModel

@{
    ViewData["Title"] = "Add Project Member";
    var project = ViewBag.Project as AryamanBMS.Models.ProjectModel;
}

<div class="module-header">
    <div>
        <h1 class="module-title">Add Project Member</h1>
        <p class="module-subtitle">
            @(project != null
                        ? $"{project.ProjectCode} - {project.ProjectName}"
                        : "Assign an employee to the project")
        </p>
    </div>

    <a asp-action="Index"
       asp-route-projectId="@Model.ProjectId"
       class="btn-app btn-secondary-app">
        Back
    </a>
</div>

<form asp-action="Add"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden"
           asp-for="ProjectId" />

    <div asp-validation-summary="ModelOnly"
         class="validation-message">
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Member Assignment</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label asp-for="EmployeeId">
                        Employee
                    </label>

                    <select asp-for="EmployeeId"
                            class="app-select">

                        <option value="">
                            Select Employee
                        </option>

                        @foreach (var employee in ViewBag.Employees)
                        {
                            <option value="@employee.Id">
                                @employee.EmployeeCode - @employee.FullName
                            </option>
                        }
                    </select>

                    <span asp-validation-for="EmployeeId"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="RoleInProject">
                        Role in Project
                    </label>

                    <input asp-for="RoleInProject"
                           class="app-input"
                           placeholder="Example: Developer, Tester, Coordinator" />

                    <span asp-validation-for="RoleInProject"
                          class="validation-message">
                    </span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-body">
            <button type="submit"
                    class="btn-app btn-primary-app">
                <i class="bi bi-check-lg"></i>
                Add Member
            </button>

            <a asp-action="Index"
               asp-route-projectId="@Model.ProjectId"
               class="btn-app btn-secondary-app">
                Cancel
            </a>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}