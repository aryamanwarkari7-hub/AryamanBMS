@model AryamanBMS.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<div class="module-header">

    <div>
        <h2>Reset Password</h2>
        <p>Set a new password for the selected user.</p>
    </div>

</div>

<div class="app-card p-4">

    <form asp-action="ResetPassword" method="post">

        <input asp-for="UserId" type="hidden" />

        <div asp-validation-summary="ModelOnly"
             class="text-danger mb-3">
        </div>

        <div class="mb-3">

            <label class="form-label">
                Username
            </label>

            <input asp-for="UserName"
                   class="app-input"
                   readonly />

        </div>

        <div class="mb-3">

            <label asp-for="NewPassword"
                   class="form-label">
            </label>

            <input asp-for="NewPassword"
                   class="app-input" />

            <span asp-validation-for="NewPassword"
                  class="text-danger">
            </span>

        </div>

        <div class="mb-4">

            <label asp-for="ConfirmPassword"
                   class="form-label">
            </label>

            <input asp-for="ConfirmPassword"
                   class="app-input" />

            <span asp-validation-for="ConfirmPassword"
                  class="text-danger">
            </span>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn-app btn-primary-app">

                <i class="bi bi-key"></i>
                Reset Password

            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">

                Back

            </a>

        </div>

    </form>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}