@model PagedListViewModel<UserListViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="module-header">

    <div>

        <h1 class="module-title">
            Users
        </h1>

        <p class="module-subtitle">
            Manage system users and roles
        </p>

    </div>

    <div class="module-header-actions">

        <a asp-action="Create"
           class="btn-app btn-primary-app">

            <i class="bi bi-plus-lg"></i>
            Create User

        </a>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">
            Search and Sort
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-end">

            <div class="col-lg-5 col-md-6">

                <label class="form-label">
                    Search
                </label>

                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="form-control"
                       placeholder="Name, username, email or role" />

            </div>

            <div class="col-lg-4 col-md-6">

                <label class="form-label">
                    Sort By
                </label>

                <select name="sortBy"
                        class="form-select">

                    <option value="NameAsc"
                            selected="@(ViewBag.SortBy == "NameAsc")">
                        Name: A to Z
                    </option>

                    <option value="NameDesc"
                            selected="@(ViewBag.SortBy == "NameDesc")">
                        Name: Z to A
                    </option>

                    <option value="UserNameAsc"
                            selected="@(ViewBag.SortBy == "UserNameAsc")">
                        Username: A to Z
                    </option>

                    <option value="UserNameDesc"
                            selected="@(ViewBag.SortBy == "UserNameDesc")">
                        Username: Z to A
                    </option>

                    <option value="EmailAsc"
                            selected="@(ViewBag.SortBy == "EmailAsc")">
                        Email: A to Z
                    </option>

                    <option value="EmailDesc"
                            selected="@(ViewBag.SortBy == "EmailDesc")">
                        Email: Z to A
                    </option>

                    <option value="RoleAsc"
                            selected="@(ViewBag.SortBy == "RoleAsc")">
                        Role: A to Z
                    </option>

                    <option value="RoleDesc"
                            selected="@(ViewBag.SortBy == "RoleDesc")">
                        Role: Z to A
                    </option>

                    <option value="StatusAsc"
                            selected="@(ViewBag.SortBy == "StatusAsc")">
                        Active First
                    </option>

                    <option value="StatusDesc"
                            selected="@(ViewBag.SortBy == "StatusDesc")">
                        Inactive First
                    </option>

                </select>

            </div>

            <div class="col-lg-3 col-md-12">

                <div class="d-flex gap-2">

                    <button type="submit"
                            class="btn-app btn-primary-app">

                        <i class="bi bi-search"></i>
                        Search

                    </button>

                    <a asp-action="Index"
                       class="btn-app btn-secondary-app">

                        <i class="bi bi-arrow-counterclockwise"></i>
                        Reset

                    </a>

                </div>

            </div>

        </form>

    </div>

</div>


<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            User List
        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-people"></i>

                <p class="mb-0">
                    No users found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>User Name</th>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var user in Model.Items)
                        {
                            <tr>

                                <td>
                                    <strong>
                                        @(string.IsNullOrWhiteSpace(user.FullName)
                                            ? "-"
                                            : user.FullName)
                                    </strong>
                                </td>

                                <td>
                                    @user.UserName
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(user.Email)
                                        ? "-"
                                        : user.Email)
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(user.Role)
                                        ? "Not Assigned"
                                        : user.Role)
                                </td>

                                <td>

                                    @if (user.IsActive)
                                    {
                                        <span class="badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="btn-app btn-primary-app btn-icon"
                                           title="Edit user"
                                           aria-label="Edit user">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="ResetPassword"
                                           asp-route-id="@user.Id"
                                           class="btn-app btn-success-app btn-icon"
                                           title="Reset password"
                                           aria-label="Reset password">

                                            <i class="bi bi-key"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>