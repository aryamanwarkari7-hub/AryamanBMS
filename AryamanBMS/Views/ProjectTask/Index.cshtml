@model IEnumerable<AryamanBMS.Models.ProjectTaskModel>

@{
    ViewData["Title"] = "Tasks";
}

<div class="module-header">
    <div>
        <h1 class="module-title">Tasks</h1>
        <p class="module-subtitle">Manage tasks across projects</p>
    </div>

    <a asp-action="Create"
       asp-route-projectId="@ViewBag.ProjectId"
       class="btn-app btn-primary-app">
        <i class="bi bi-plus-lg"></i>
        Add Task
    </a>
</div>



<div class="app-card">
    <div class="card-body">

        <form method="get" asp-action="Index">
            <div class="form-grid-4">

                <div class="form-group">
                    <label>Project</label>

                    <select name="projectId"
                            class="app-select">

                        <option value="">All Projects</option>

                        @foreach (var project in ViewBag.Projects)
                        {
                            <option value="@project.Id"
                                    selected="@(ViewBag.ProjectId == project.Id)">
                                @project.ProjectCode - @project.ProjectName
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label>Search</label>

                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"
                           class="app-input"
                           placeholder="Code or task title" />
                </div>

                <div class="form-group">
                    <label>Status</label>

                    <select name="status"
                            class="app-select">

                        <option value="">All Statuses</option>
                        <option value="Not Started"
                                selected="@(ViewBag.Status == "Not Started")">
                            Not Started
                        </option>
                        <option value="In Progress"
                                selected="@(ViewBag.Status == "In Progress")">
                            In Progress
                        </option>
                        <option value="Completed"
                                selected="@(ViewBag.Status == "Completed")">
                            Completed
                        </option>
                        <option value="On Hold"
                                selected="@(ViewBag.Status == "On Hold")">
                            On Hold
                        </option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Priority</label>

                    <select name="priority"
                            class="app-select">

                        <option value="">All Priorities</option>
                        <option value="Low"
                                selected="@(ViewBag.Priority == "Low")">
                            Low
                        </option>
                        <option value="Medium"
                                selected="@(ViewBag.Priority == "Medium")">
                            Medium
                        </option>
                        <option value="High"
                                selected="@(ViewBag.Priority == "High")">
                            High
                        </option>
                        <option value="Critical"
                                selected="@(ViewBag.Priority == "Critical")">
                            Critical
                        </option>
                    </select>
                </div>

            </div>

            <div class="mt-3">
                <button type="submit"
                        class="btn-app btn-primary-app">
                    Filter
                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">
                    Reset
                </a>
            </div>
        </form>

    </div>
</div>

<div class="app-card table-card">
    <div class="card-header">
        <h5 class="card-title">Task List</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <thead>
                <tr>
                    <th>Task Code</th>
                    <th>Task Title</th>
                    <th>Project</th>
                    <th>Assigned To</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Progress</th>
                    <th>Due Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var task in Model)
                    {
                        <tr>
                            <td>@task.TaskCode</td>

                            <td>@task.TaskTitle</td>

                            <td>
                                @task.Project?.ProjectCode
                            </td>

                            <td>
                                @(task.AssignedEmployee?.FullName ?? "-")
                            </td>

                            <td>@task.Priority</td>

                            <td>@task.Status</td>

                            <td>
                                @task.ProgressPercent%
                            </td>

                            <td>
                                @(task.DueDate?.ToString("dd-MM-yyyy") ?? "-")
                            </td>

                            <td>
                                <div class="action-buttons d-flex flex-row gap-1">

                                    <a asp-action="Details"
                                       asp-route-id="@task.Id"
                                       class="btn-app btn-primary-app btn-icon"
                                       title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@task.Id"
                                       class="btn-app btn-secondary-app btn-icon"
                                       title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@task.Id"
                                       class="btn-app btn-danger-app btn-icon"
                                       title="Deactivate">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9"
                            class="text-center text-muted">
                            No project tasks found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (ViewBag.TotalPages > 1)
{
    <div class="pagination-container">

        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a asp-action="Index"
               asp-route-page="@i"
               asp-route-projectId="@ViewBag.ProjectId"
               asp-route-searchText="@ViewBag.SearchText"
               asp-route-status="@ViewBag.Status"
               asp-route-priority="@ViewBag.Priority"
               class="page-link-app @(i == ViewBag.CurrentPage ? "active" : "")">
                @i
            </a>
        }

    </div>
}