@model IEnumerable<AryamanBMS.ViewModels.RoleListViewModel>

@{
    ViewData["Title"] = "User Roles";
}

<div class="module-header">

    <div>
        <h1 class="module-title">User Roles</h1>

        <p class="module-subtitle">
            Manage application roles
        </p>
    </div>

    <a asp-action="Create"
       class="btn-app btn-primary-app">

        <i class="bi bi-plus-lg"></i>
        Add Role

    </a>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Filter Roles</h5>
    </div>

    <div class="card-body">

        <form asp-action="Index"
              method="get"
              class="row g-3 align-items-end">

            <div class="col-md-4">

                <label class="form-label">
                    Role Status
                </label>

                <select name="status"
                        class="form-select">

                    <option value="">
                        All Roles
                    </option>

                    <option value="Active"
                            selected="@(ViewBag.Status == "Active")">
                        Active
                    </option>

                    <option value="Inactive"
                            selected="@(ViewBag.Status == "Inactive")">
                        Inactive
                    </option>

                </select>

            </div>

            <div class="col-md-4 d-flex gap-2">

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-funnel"></i>
                    Apply

                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">

                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset

                </a>

            </div>

        </form>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">
        <h5 class="card-title">Role List</h5>
    </div>

    <div class="card-body">

        @if (!Model.Any())
        {
            <div class="empty-state">
                No roles found.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Role Name</th>
                            <th>Users Assigned</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var role in Model)
                        {
                            bool isProtectedRole =
                            role.RoleName.Equals(
                            "Admin",
                            StringComparison.OrdinalIgnoreCase) ||

                            role.RoleName.Equals(
                            "HR",
                            StringComparison.OrdinalIgnoreCase) ||

                            role.RoleName.Equals(
                            "Employee",
                            StringComparison.OrdinalIgnoreCase);

                            <tr>

                                <td>
                                    <strong>
                                        @role.RoleName
                                    </strong>
                                </td>

                                <td>
                                    @role.UsersAssigned
                                </td>

                                <td>
                                    @if (role.UsersAssigned > 0)
                                    {
                                        <span class="badge-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">Inactive</span>
                                    }
                                </td>

                                <td>

                                    @if (isProtectedRole)
                                    {
                                        <span class="badge-warning">
                                            Protected
                                        </span>
                                    }
                                    else if (!role.CanDelete)
                                    {
                                        <button type="button"
                                                class="btn-app btn-danger-app btn-icon"
                                                disabled
                                                title="Users are assigned to this role">

                                            <i class="bi bi-trash"></i>

                                        </button>
                                    }
                                    else
                                    {
                                        <form asp-action="Delete"
                                              method="post"
                                              onsubmit="return confirm('Delete this role?');">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="id"
                                                   value="@role.RoleId" />

                                            <button type="submit"
                                                    class="btn-app btn-danger-app btn-icon">

                                                <i class="bi bi-trash"></i>

                                            </button>

                                        </form>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>