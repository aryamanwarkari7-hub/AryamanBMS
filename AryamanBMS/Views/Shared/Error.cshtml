@{
    ViewData["Title"] = "Something Went Wrong";
}

<div class="state-page">
    <div class="state-card">

        <div class="state-icon danger">
            <i class="bi bi-bug"></i>
        </div>

        <h1>Something Went Wrong</h1>

        <p>
            An unexpected error occurred. Please try again or contact the administrator.
        </p>

        <div class="state-actions">
            <a asp-controller="Dashboard"
               asp-action="Index"
               class="btn-app btn-primary-app">
                Go to Dashboard
            </a>
        </div>

    </div>
</div>