@model PaginationViewModel

@if (Model.TotalPages > 1)
{
    int startPage = Math.Max(1, Model.CurrentPage - 2);
    int endPage = Math.Min(
        Model.TotalPages,
        Model.CurrentPage + 2);

    <nav class="app-pagination"
         aria-label="Pagination">

        @{
            var previousRoutes =
                new Dictionary<string, string>(
                    Model.RouteValues);

            previousRoutes["page"] =
                (Model.CurrentPage - 1).ToString();
        }

        @if (Model.HasPreviousPage)
        {
            <a asp-controller="@Model.ControllerName"
               asp-action="@Model.ActionName"
               asp-all-route-data="previousRoutes"
               class="pagination-btn">

                <i class="bi bi-chevron-left"></i>
                Previous

            </a>
        }
        else
        {
            <span class="pagination-btn disabled">
                <i class="bi bi-chevron-left"></i>
                Previous
            </span>
        }

        @if (startPage > 1)
        {
            var firstPageRoutes =
                new Dictionary<string, string>(
                    Model.RouteValues);

            firstPageRoutes["page"] = "1";

            <a asp-controller="@Model.ControllerName"
               asp-action="@Model.ActionName"
               asp-all-route-data="firstPageRoutes"
               class="pagination-number">
                1
            </a>

            @if (startPage > 2)
            {
                <span class="pagination-dots">
                    ...
                </span>
            }
        }

        @for (int pageNumber = startPage;
              pageNumber <= endPage;
              pageNumber++)
        {
            var pageRoutes =
                new Dictionary<string, string>(
                    Model.RouteValues);

            pageRoutes["page"] =
                pageNumber.ToString();

            <a asp-controller="@Model.ControllerName"
               asp-action="@Model.ActionName"
               asp-all-route-data="pageRoutes"
               class="pagination-number
                @(pageNumber == Model.CurrentPage
                   ? "active"
                   : "")">

                @pageNumber

            </a>
        }

        @if (endPage < Model.TotalPages)
        {
            @if (endPage < Model.TotalPages - 1)
            {
                <span class="pagination-dots">
                    ...
                </span>
            }

            var lastPageRoutes =
                new Dictionary<string, string>(
                    Model.RouteValues);

            lastPageRoutes["page"] =
                Model.TotalPages.ToString();

            <a asp-controller="@Model.ControllerName"
               asp-action="@Model.ActionName"
               asp-all-route-data="lastPageRoutes"
               class="pagination-number">

                @Model.TotalPages

            </a>
        }

        @{
            var nextRoutes =
                new Dictionary<string, string>(
                    Model.RouteValues);

            nextRoutes["page"] =
                (Model.CurrentPage + 1).ToString();
        }

        @if (Model.HasNextPage)
        {
            <a asp-controller="@Model.ControllerName"
               asp-action="@Model.ActionName"
               asp-all-route-data="nextRoutes"
               class="pagination-btn">

                Next
                <i class="bi bi-chevron-right"></i>

            </a>
        }
        else
        {
            <span class="pagination-btn disabled">
                Next
                <i class="bi bi-chevron-right"></i>
            </span>
        }

    </nav>
}