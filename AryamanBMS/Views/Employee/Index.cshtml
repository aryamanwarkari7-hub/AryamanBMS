@model PagedListViewModel<EmployeeModel>

<div class="module-header">

    <div>
        <h1 class="module-title">Employee Master</h1>
        <p class="module-subtitle">Manage employee records</p>
    </div>

    <div class="d-flex flex-row gap-2">
         <a asp-action="Create"
            class="btn-app btn-primary-app">
             <i class="bi bi-plus-lg"></i>
             Add Employee
         </a>
         
         <a asp-action="Export"
            class="btn-app btn-success-app">
         
             <i class="bi bi-file-earmark-excel"></i>
             Export
         
         </a>
    </div>

</div>

<div class="app-card table-card">
    <div class="card-header">
        <h5 class="card-title">Employee List</h5>
    </div>

    <div class="app-card mb-3">

        <div class="card-body">

            <form asp-actions="Index"
                method="get">

                <div class="d-flex flex-wrap gap-2">

                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"

                           class="app-input flex-grow-1"
                           placeholder="Search by code, name, mobile or email" />

                    <select name="statusFilter"
                            class="app-select">

                        @if ((string)ViewBag.Status == "Active")
                        {
                            <option value="Active" selected>Active</option>
                        }
                        else
                        {
                            <option value="Active">Active</option>
                        }

                        @if ((string)ViewBag.Status == "Inactive")
                        {
                            <option value="Inactive" selected>Inactive</option>
                        }
                        else
                        {
                            <option value="Inactive">Inactive</option>
                        }

                        @if ((string)ViewBag.Status == "All")
                        {
                            <option value="All" selected>All</option>
                        }
                        else
                        {
                            <option value="All">All</option>
                        }

                    </select>

                    <button type="submit"
                            class="btn-app btn-primary-app">
                        <i class="bi bi-search"></i>
                        Search
                    </button>

                    <a asp-action="Index"
                       class="btn-app btn-secondary-app">
                        Reset
                    </a>

                </div>

            </form>

        </div>

    </div>

    <div class="card-body">
        <div class="table-responsive">
            @if (!Model.Items.Any())
            {
                <div class="empty-state">
                    No records found.
                </div>
            }
            else
            {
                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Official Email</th>
                            <th>Mobile</th>
                            <th>Employment Type</th>
                            <th>Status</th>
                            <th>User</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var employee in Model.Items)
                        {
                            <tr>

                                <td>
                                    <strong>@employee.EmployeeCode</strong>
                                </td>

                                <td>
                                    <div>
                                        <strong>@employee.FullName</strong>
                                        <br />
                                        <small>
                                            DOJ:
                                            @employee.JoiningDate.ToString("dd-MMM-yyyy")
                                        </small>
                                    </div>
                                </td>

                                <td>
                                    @(employee.Department?.DepartmentName ?? "-")
                                </td>

                                <td>
                                    @(employee.Designation?.DesignationName ?? "-")
                                </td>

                                <td>
                                    @(employee.OfficialEmail ?? "-")
                                </td>

                                <td>
                                    @(employee.MobileNumber ?? "-")
                                </td>

                                <td>
                                    @(employee.EmploymentType ?? "-")
                                </td>

                                <td>
                                    @if (employee.IsActive)
                                    {
                                        <span class="badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">
                                            Inactive
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(employee.ApplicationUser?.UserName ?? "-")
                                </td>

                                <td>
                                    <div class="table-actions">

                                        <a asp-action="Details"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-primary-app btn-icon">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-secondary-app btn-icon">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-danger-app btn-icon">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }
        </div>

        <partial name="_Pagination"
                 model="Model.Pagination" />

            </div>
        }
    </div>

</div>