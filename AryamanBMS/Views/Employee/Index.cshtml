@model List<AryamanBMS.Models.EmployeeModel>

<div class="module-header">

    <div>
        <h1 class="module-title">Employee Master</h1>
        <p class="module-subtitle">Manage employee records</p>
    </div>

    <div class="d-flex flex-row gap-2">
         <a asp-action="Create"
            class="btn-app btn-primary-app">
             <i class="bi bi-plus-lg"></i>
             Add Employee
         </a>
         
         <a asp-action="Export"
            class="btn-app btn-success-app">
         
             <i class="bi bi-file-earmark-excel"></i>
             Export
         
         </a>
    </div>

</div>

<div class="app-card table-card">
    @if (TempData["Error"] != null)
    {
        <div class="app-alert app-alert-danger">
            @TempData["Error"]
        </div>
    }
    <div class="card-header">
        <h5 class="card-title">Employee List</h5>
    </div>

    <div class="app-card mb-3">

        <div class="card-body">

            <form method="get">

                <div class="d-flex gap-2">

                    <input type="text"
                           name="searchText"
                           value="@ViewBag.SearchText"
                           class="app-input"
                           placeholder="Search by code, name, mobile or email" />

                    <button type="submit"
                            class="btn-app btn-primary-app">
                        <i class="bi bi-search"></i>
                        Search
                    </button>

                    <a asp-action="Index"
                       class="btn-app btn-secondary-app">
                        Reset
                    </a>

                </div>

            </form>

        </div>

    </div>

    <div class="card-body">
        <div class="table-responsive">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    No records found.
                </div>
            }
            else
            {
                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Employee</th>
                            <th>Department</th>
                            <th>Designation</th>
                            <th>Official Email</th>
                            <th>Mobile</th>
                            <th>Employment Type</th>
                            <th>Status</th>
                            <th>User</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var employee in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@employee.EmployeeCode</strong>
                                </td>

                                <td>
                                    <div>
                                        <strong>@employee.FullName</strong>
                                        <br />
                                        <small>
                                            DOJ:
                                            @employee.JoiningDate.ToString("dd-MMM-yyyy")
                                        </small>
                                    </div>
                                </td>

                                <td>
                                    @(employee.Department?.DepartmentName ?? "-")
                                </td>

                                <td>
                                    @(employee.Designation?.DesignationName ?? "-")
                                </td>

                                <td>
                                    @(employee.OfficialEmail ?? "-")
                                </td>

                                <td>
                                    @(employee.MobileNumber ?? "-")
                                </td>

                                <td>
                                    @(employee.EmploymentType ?? "-")
                                </td>

                                <td>
                                    @if (employee.IsActive)
                                    {
                                        <span class="badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">
                                            Inactive
                                        </span>
                                    }
                                </td>

                                <td>
                                    @(employee.ApplicationUser?.UserName ?? "-")
                                </td>

                                <td>
                                    <div class="table-actions">

                                        <a asp-action="Details"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-primary-app btn-icon">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-secondary-app btn-icon">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@employee.Id"
                                           class="btn-app btn-danger-app btn-icon">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <div class="pagination-container">

                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)"
                       asp-route-searchText="@ViewBag.SearchText"
                       class="btn-app btn-secondary-app">
                        Previous
                    </a>
                }

                <span class="pagination-info">
                    Page @ViewBag.CurrentPage of @ViewBag.TotalPages
                </span>

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)"
                       asp-route-searchText="@ViewBag.SearchText"
                       class="btn-app btn-secondary-app">
                        Next
                    </a>
                }

            </div>
        }
    </div>

</div>