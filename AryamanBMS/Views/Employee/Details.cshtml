
@model AryamanBMS.Models.EmployeeModel

@{
    ViewData["Title"] = "Employee Details";
}

<div class="module-header">
    <div>
        <h1 class="module-title">Employee Details</h1>
        <p class="module-subtitle">View employee information</p>
    </div>

    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-app btn-primary-app">
        Edit Employee
    </a>
</div>

<!-- Basic Information Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Basic Information</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Employee Code</th>
                    <td>@Model.EmployeeCode</td>
                </tr>

                <tr>
                    <th>Employee Name</th>
                    <td>@Model.FullName</td>
                </tr>

                <tr>
                    <th>Gender</th>
                    <td>@(Model.Gender ?? "-")</td>
                </tr>

                <tr>
                    <th>Date Of Birth</th>
                    <td>
                        @(Model.DateOfBirth?.ToString("dd-MMM-yyyy") ?? "-")
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Employment Information Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Employment Information</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Department</th>
                    <td>@Model.Department?.DepartmentName</td>
                </tr>

                <tr>
                    <th>Designation</th>
                    <td>@Model.Designation?.DesignationName</td>
                </tr>

                <tr>
                    <th>Joining Date</th>
                    <td>@Model.JoiningDate.ToString("dd-MMM-yyyy")</td>
                </tr>

                <tr>
                    <th>Employment Type</th>
                    <td>@(Model.EmploymentType ?? "-")</td>
                </tr>

                <tr>
                    <th>System User</th>
                    <td>@(Model.ApplicationUser?.UserName ?? "-")</td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="badge-success">Active</span>
                        }
                        else
                        {
                            <span class="badge-danger">Inactive</span>
                        }
                    </td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Contact Information Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Contact Information</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Mobile Number</th>
                    <td>@(Model.MobileNumber ?? "-")</td>
                </tr>

                <tr>
                    <th>Personal Email</th>
                    <td>@(Model.PersonalEmail ?? "-")</td>
                </tr>

                <tr>
                    <th>Official Email</th>
                    <td>@(Model.OfficialEmail ?? "-")</td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Address Information Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Address Information</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Permanent Address</th>
                    <td>@(Model.PermanentAddress ?? "-")</td>
                </tr>

                <tr>
                    <th>City</th>
                    <td>@(Model.City ?? "-")</td>
                </tr>

                <tr>
                    <th>State</th>
                    <td>@(Model.State ?? "-")</td>
                </tr>

                <tr>
                    <th>Pin Code</th>
                    <td>@(Model.PinCode ?? "-")</td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Emergency Contact Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Emergency Contact</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Emergency Contact</th>
                    <td>@(Model.EmergencyContact ?? "-")</td>
                </tr>

                <tr>
                    <th>Emergency Phone</th>
                    <td>@(Model.EmergencyPhone ?? "-")</td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Statutory Information Card -->
<div class="app-card">
    <div class="card-header">
        <h5 class="card-title">Statutory Information</h5>
    </div>

    <div class="card-body">
        <table class="app-table">
            <tbody>

                <tr>
                    <th>Aadhaar Number</th>
                    <td>@(Model.AadhaarNo ?? "-")</td>
                </tr>

                <tr>
                    <th>PAN Number</th>
                    <td>@(Model.PanNo ?? "-")</td>
                </tr>

                <tr>
                    <th>UAN Number</th>
                    <td>@(Model.UanNo ?? "-")</td>
                </tr>

            </tbody>
        </table>
    </div>
</div>

<!-- Academic Information Card -->
<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">
            Academic Information
        </h5>
    </div>

    <div class="card-body">

        @if (!Model.AcademicRecords.Any())
        {
            <div class="empty-state">
                No academic records found.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Qualification</th>
                            <th>Course</th>
                            <th>Institute</th>
                            <th>University</th>
                            <th>Year</th>
                            <th>Result</th>
                            <th>Highest</th>
                            <th>Documents</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var academic in
                            Model.AcademicRecords
                                .OrderByDescending(x => x.PassingYear))
                        {
                            <tr>

                                <td>
                                    @academic.QualificationLevel
                                </td>

                                <td>
                                    @(academic.CourseName ?? "-")

                                    @if (!string.IsNullOrWhiteSpace(
                                        academic.Specialization))
                                    {
                                        <br />
                                        <small>
                                            @academic.Specialization
                                        </small>
                                    }
                                </td>

                                <td>
                                    @(academic.InstituteName ?? "-")
                                </td>

                                <td>
                                    @(academic.BoardOrUniversity ?? "-")
                                </td>

                                <td>
                                    @(academic.PassingYear?.ToString() ?? "-")
                                </td>

                                <td>
                                    @if (academic.ResultType == "Grade")
                                    {
                                        @(academic.Grade ?? "-")
                                    }
                                    else if (academic.Score.HasValue)
                                    {
                                        @academic.Score
                                        <span>
                                            @academic.ResultType
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>
                                    @if (academic.IsHighestQualification)
                                    {
                                        <span class="badge-success">
                                            Yes
                                        </span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>

                                <td>

                                    @if (academic.Documents.Any())
                                    {
                                        <div class="d-flex flex-column gap-1">

                                            @foreach (var document in academic.Documents)
                                            {
                                                <a asp-action="DownloadDocument"
                                                   asp-route-id="@document.Id"
                                                   class="btn-app btn-outline-app">

                                                    <i class="bi bi-download"></i>
                                                    @document.OriginalFileName

                                                </a>
                                            }

                                        </div>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>

<!-- Actions Card -->
<div class="app-card">
    <div class="card-body">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-app btn-primary-app">
            Edit Employee
        </a>

        <a asp-action="Index" class="btn-app btn-secondary-app">
            Back
        </a>
    </div>
</div>

```