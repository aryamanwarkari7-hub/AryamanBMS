@model AryamanBMS.Models.EmployeeModel

<div class="module-header">
    <div>
        <h1 class="module-title">Add Employee</h1>
        <p class="module-subtitle">Create a new employee</p>
    </div>
</div>


<form asp-action="Create" method="post">

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Basic Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Employee Code</label>
                    <input asp-for="EmployeeCode" class="app-input" />
                    <span asp-validation-for="EmployeeCode" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select asp-for="Gender" class="app-select">
                        <option value="">Select Gender</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input asp-for="FirstName" class="app-input" />
                    <span asp-validation-for="FirstName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input asp-for="LastName" class="app-input" />
                    <span asp-validation-for="LastName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Date Of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="app-input" />
                    <span asp-validation-for="DateOfBirth" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Employment Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Joining Date</label>
                    <input asp-for="JoiningDate" type="date" class="app-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Employment Type</label>
                    <select asp-for="EmploymentType" class="app-select">
                        <option value="">Select Type</option>
                        <option>Permanent</option>
                        <option>Contract</option>
                        <option>Intern</option>
                        <option>Consultant</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select asp-for="DepartmentId" id="departmentDropdown" class="app-select">
                        <option value="">Select Department</option>
                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.Id">
                                @department.DepartmentName
                            </option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Designation</label>
                    <select asp-for="DesignationId" id="designationDropdown" class="app-select">
                        <option value="">Select Designation</option>
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">System User</label>
                    <select asp-for="ApplicationUserId" class="app-select">
                        <option value="">Select User</option>
                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Id">
                                @user.FullName (@user.UserName)
                            </option>
                        }
                    </select>
                    <span asp-validation-for="ApplicationUserId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="IsActive" class="app-select">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Contact Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Mobile Number</label>
                    <input asp-for="MobileNumber" class="app-input" />
                    <span asp-validation-for="MobileNumber" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Personal Email</label>
                    <input asp-for="PersonalEmail" type="email" class="app-input" />
                    <span asp-validation-for="PersonalEmail" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Official Email</label>
                    <input asp-for="OfficialEmail" type="email" class="app-input" />
                    <span asp-validation-for="OfficialEmail" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Address Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Permanent Address</label>
                    <textarea asp-for="PermanentAddress" class="app-textarea"></textarea>
                </div>

                <div class="form-group">
                    <label class="form-label">City</label>
                    <input asp-for="City" class="app-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">State</label>
                    <input asp-for="State" class="app-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Pin Code</label>
                    <input asp-for="PinCode" class="app-input" />
                    <span asp-validation-for="PinCode" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Emergency Contact</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Emergency Contact</label>
                    <input asp-for="EmergencyContact" class="app-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">Emergency Phone</label>
                    <input asp-for="EmergencyPhone" class="app-input" />
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Statutory Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Aadhaar Number</label>
                    <input asp-for="AadhaarNo" class="app-input" />
                    <span asp-validation-for="AadhaarNo" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">PAN Number</label>
                    <input asp-for="PanNo" class="app-input" />
                    <span asp-validation-for="PanNo" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">UAN Number</label>
                    <input asp-for="UanNo" class="app-input" />
                    <span asp-validation-for="UanNo" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-body">
            <button type="submit" class="btn-app btn-primary-app">
                Save Employee
            </button>

            <a asp-action="Index" class="btn-app btn-secondary-app">
                Cancel
            </a>
        </div>
    </div>

</form>

<script>
    function loadDesignations(departmentId, selectedDesignationId = null)
    {
        fetch('/Employee/GetDesignations?departmentId=' + departmentId)
            .then(response => response.json())
            .then(data =>
            {
                let dropdown = document.getElementById('designationDropdown');
                dropdown.innerHTML = '<option value="">Select Designation</option>';

                data.forEach(function (designation)
                {
                    let selected = designation.id == selectedDesignationId ? 'selected' : '';
                    dropdown.innerHTML += `<option value="${designation.id}" ${selected}>${designation.designationName}</option>`;
                });
            });
    }

    document.getElementById('departmentDropdown').addEventListener('change', function ()
    {
        fetch('/Employee/GetDesignations?departmentId=' + this.value)
            .then(response => response.json())
            .then(data =>
            {
                let dropdown = document.getElementById('designationDropdown');
                dropdown.innerHTML = '<option value="">Select Designation</option>';

                data.forEach(function (designation)
                {
                    dropdown.innerHTML += `<option value="${designation.id}">${designation.designationName}</option>`;
                });
            });
    });
</script>