@model EmployeeFormViewModel
@{
    string currentPermanentCity = Model.Employee.City ?? string.Empty;
    string currentPermanentPin = Model.Employee.PinCode ?? string.Empty;
    string currentLocalCity = Model.Employee.LocalCity ?? string.Empty;
    string currentLocalPin = Model.Employee.LocalPinCode ?? string.Empty;
    int currentDesignationId = Model.Employee.DesignationId;
}

<div class="module-header">
    <div>
        <h1 class="module-title">Add Employee</h1>
        <p class="module-subtitle">Create a new employee</p>
    </div>
</div>

<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly"
             class="app-alert app-alert-danger mb-3">
        </div>
    }

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Basic Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Employee Code</label>
                    <input asp-for="Employee.EmployeeCode" class="app-input" />
                    <span asp-validation-for="Employee.EmployeeCode" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select asp-for="Employee.Gender" class="app-select">
                        <option value="">Select Gender</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="Employee.Gender"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input asp-for="Employee.FirstName" class="app-input" />
                    <span asp-validation-for="Employee.FirstName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Middle Name</label>

                    <input asp-for="Employee.MiddleName"
                           class="app-input" />

                    <span asp-validation-for="Employee.MiddleName"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input asp-for="Employee.LastName" class="app-input" />
                    <span asp-validation-for="Employee.LastName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Date Of Birth</label>
                    <input asp-for="Employee.DateOfBirth" type="date" class="app-input" />
                    <span asp-validation-for="Employee.DateOfBirth" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Employment Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Joining Date</label>
                    <input asp-for="Employee.JoiningDate" type="date" class="app-input" />
                    <span asp-validation-for="Employee.JoiningDate"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Employment Type</label>
                    <select asp-for="Employee.EmploymentType" class="app-select">
                        <option value="">Select Type</option>
                        <option>Permanent</option>
                        <option>Contract</option>
                        <option>Intern</option>
                        <option>Consultant</option>
                    </select>
                    <span asp-validation-for="Employee.EmploymentType"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select asp-for="Employee.DepartmentId" id="departmentDropdown" class="app-select">
                        <option value="">Select Department</option>
                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.Id">
                                @department.DepartmentName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.DepartmentId"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Designation</label>
                    <select asp-for="Employee.DesignationId" id="designationDropdown" class="app-select">
                        <option value="">Select Designation</option>
                    </select>
                    <span asp-validation-for="Employee.DesignationId"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">System User</label>
                    <select asp-for="Employee.ApplicationUserId" class="app-select">
                        <option value="">Select User</option>
                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Id">
                                @user.FullName (@user.UserName)
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.ApplicationUserId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Employee.IsActive" class="app-select">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                    <span asp-validation-for="Employee.IsActive"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Contact Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Mobile Number</label>
                    <input asp-for="Employee.MobileNumber" class="app-input" />
                    <span asp-validation-for="Employee.MobileNumber" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Personal Email</label>
                    <input asp-for="Employee.PersonalEmail" type="email" class="app-input" />
                    <span asp-validation-for="Employee.PersonalEmail" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Official Email</label>
                    <input asp-for="Employee.OfficialEmail" type="email" class="app-input" />
                    <span asp-validation-for="Employee.OfficialEmail" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Address Information</h5>
        </div>

        <div class="card-body">

            <h6 class="mb-3">Permanent Address</h6>

            <div class="row g-3">

                <div class="col-md-12">

                    <label asp-for="Employee.PermanentAddress"
                           class="form-label">
                        Permanent Address
                    </label>

                    <textarea asp-for="Employee.PermanentAddress"
                              id="permanentAddress"
                              class="app-textarea"
                              rows="3"></textarea>

                    <span asp-validation-for="Employee.PermanentAddress"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.State"
                           class="form-label">
                        Permanent State
                    </label>

                    <select asp-for="Employee.State"
                            id="permanentStateDropdown"
                            class="app-select">

                        <option value="">Select State</option>

                        @foreach (var state in ViewBag.States)
                        {
                            <option value="@state.StateName"
                                    data-state-id="@state.Id">
                                @state.StateName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="Employee.State"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.City"
                           class="form-label">
                        Permanent City
                    </label>

                    <select asp-for="Employee.City"
                            id="permanentCityDropdown"
                            class="app-select"
                            disabled>

                        <option value="">Select City</option>

                    </select>

                    <span asp-validation-for="Employee.City"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.PinCode"
                           class="form-label">
                        Permanent PIN Code
                    </label>

                    <input asp-for="Employee.PinCode"
                           id="permanentPinCodeInput"
                           list="permanentPinCodeOptions"
                           class="app-input"
                           maxlength="6"
                           inputmode="numeric"
                           placeholder="Select or type PIN code" />

                    <datalist id="permanentPinCodeOptions"></datalist>

                    <span asp-validation-for="Employee.PinCode"
                          class="validation-message"></span>

                </div>

            </div>

            <hr class="my-4" />

            <div class="d-flex align-items-center gap-2 mb-3">

                <input type="checkbox"
                       id="sameAsPermanent"
                       class="form-check-input" />

                <label for="sameAsPermanent"
                       class="form-check-label">

                    Local address is same as permanent address

                </label>

            </div>

            <h6 class="mb-3">Local Address</h6>

            <div class="row g-3">

                <div class="col-md-12">

                    <label asp-for="Employee.LocalAddress"
                           class="form-label">
                        Local Address
                    </label>

                    <textarea asp-for="Employee.LocalAddress"
                              id="localAddress"
                              class="app-textarea"
                              rows="3"></textarea>

                    <span asp-validation-for="Employee.LocalAddress"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalState"
                           class="form-label">
                        Local State
                    </label>

                    <select asp-for="Employee.LocalState"
                            id="localStateDropdown"
                            class="app-select">

                        <option value="">Select State</option>

                        @foreach (var state in ViewBag.States)
                        {
                            <option value="@state.StateName"
                                    data-state-id="@state.Id">
                                @state.StateName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="Employee.LocalState"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalCity"
                           class="form-label">
                        Local City
                    </label>

                    <select asp-for="Employee.LocalCity"
                            id="localCityDropdown"
                            class="app-select"
                            disabled>

                        <option value="">Select City</option>

                    </select>

                    <span asp-validation-for="Employee.LocalCity"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalPinCode"
                           class="form-label">
                        Local PIN Code
                    </label>

                    <input asp-for="Employee.LocalPinCode"
                           id="localPinCodeInput"
                           list="localPinCodeOptions"
                           class="app-input"
                           maxlength="6"
                           inputmode="numeric"
                           placeholder="Select or type PIN code" />

                    <datalist id="localPinCodeOptions"></datalist>

                    <span asp-validation-for="Employee.LocalPinCode"
                          class="validation-message"></span>

                </div>

            </div>

        </div>

    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Emergency Contact</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Emergency Contact Name</label>
                    <input asp-for="Employee.EmergencyContact" class="app-input" />
                    <span asp-validation-for="Employee.EmergencyContact"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Emergency Contact Number</label>
                    <input asp-for="Employee.EmergencyPhone" class="app-input" />
                    <span asp-validation-for="Employee.EmergencyPhone"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Statutory Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Aadhaar Number</label>
                    <input asp-for="Employee.AadhaarNo"
                           class="app-input"
                           maxlength="12"
                           inputmode="numeric"
                           placeholder="Enter 12-digit Aadhaar number" />
                    <span asp-validation-for="Employee.AadhaarNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">PAN Number</label>
                    <input asp-for="Employee.PanNo"
                           class="app-input"
                           maxlength="10"
                           placeholder="Enter 10-character PAN number" />
                    <span asp-validation-for="Employee.PanNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">UAN Number</label>
                    <input asp-for="Employee.UanNo"
                           class="app-input"
                           maxlength="12"
                           inputmode="numeric"
                           placeholder="Enter 12-digit UAN number" />
                    <span asp-validation-for="Employee.UanNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">ESIC Number</label>

                    <input asp-for="Employee.EsicNo"
                           class="app-input"
                           maxlength="10"
                           inputmode="numeric"
                           pattern="[0-9]{10}"
                           placeholder="Enter 10-digit ESIC number" />

                    <span asp-validation-for="Employee.EsicNo"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Statutory Documents</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                @for (int i = 0;
                                i < Model.StatutoryDocuments.Count;
                                i++)
                {
                    <div class="form-group">

                        <input asp-for="StatutoryDocuments[i].DocumentType"
                               type="hidden" />

                        <label class="form-label">
                            @Model.StatutoryDocuments[i].DocumentType
                        </label>

                        <input asp-for="StatutoryDocuments[i].File"
                               type="file"
                               accept=".pdf,application/pdf"
                               class="form-control document-pdf-input" />

                        <span asp-validation-for="StatutoryDocuments[i].File"
                              class="validation-message"></span>

                        <small class="text-muted">
                            PDF only. Maximum size: 5 MB.
                        </small>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Joining Documents</h5>
        </div>

        <div class="card-body">

            @for (int i = 0;
                        i < Model.JoiningDocuments.Count;
                        i++)
            {
                <div class="row align-items-center
                            border-bottom py-3">

                    <div class="col-md-4">

                        <input asp-for="JoiningDocuments[i].DocumentType"
                               type="hidden" />

                        <label class="form-label mb-0">
                            @Model.JoiningDocuments[i].DocumentType
                        </label>

                    </div>

                    <div class="col-md-8">

                        <input asp-for="JoiningDocuments[i].File"
                               type="file"
                               accept=".pdf,application/pdf"
                               class="form-control document-pdf-input" />

                        <span asp-validation-for="JoiningDocuments[i].File"
                              class="validation-message"></span>

                    </div>

                </div>
            }

            <small class="text-muted d-block mt-3">
                Upload PDF files only. Maximum size: 5 MB per document.
            </small>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header d-flex justify-content-between">

            <h5 class="card-title">
                Academic Information
            </h5>

            <button type="button"
                    id="addAcademic"
                    class="btn-app btn-primary-app">

                <i class="bi bi-plus-lg"></i>
                Add Qualification

            </button>

        </div>

        <div class="card-body">

            <div id="academicContainer">

                @for (int i = 0; i < Model.Academics.Count; i++)
                {
                    <div class="academic-item border rounded p-3 mb-3">

                        <input type="hidden"
                               name="Academics.Index"
                               value="@i" />

                        <div class="form-grid-2">

                            <div class="form-group">

                                <label class="form-label">
                                    Qualification Level
                                </label>

                                <select asp-for="Academics[i].QualificationLevel"
                                        class="app-select">

                                    <option value="">Select Qualification</option>
                                    <option>10th</option>
                                    <option>12th</option>
                                    <option>Diploma</option>
                                    <option>Graduation</option>
                                    <option>Post Graduation</option>
                                    <option>Doctorate</option>
                                    <option>Certification</option>
                                    <option>Other</option>

                                </select>

                            </div>

                            <div class="form-group">
                                <label class="form-label">Course Name</label>
                                <input asp-for="Academics[i].CourseName"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Specialization</label>
                                <input asp-for="Academics[i].Specialization"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Institute</label>
                                <input asp-for="Academics[i].InstituteName"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Board / University</label>
                                <input asp-for="Academics[i].BoardOrUniversity"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Passing Year</label>
                                <input asp-for="Academics[i].PassingYear"
                                       type="number"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Result Type</label>

                                <select asp-for="Academics[i].ResultType"
                                        class="app-select">

                                    <option value="">Select Result Type</option>
                                    <option>Percentage</option>
                                    <option>CGPA</option>
                                    <option>Grade</option>

                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Score</label>
                                <input asp-for="Academics[i].Score"
                                       type="number"
                                       step="0.01"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Grade</label>
                                <input asp-for="Academics[i].Grade"
                                       class="app-input" />
                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Document Type
                                </label>

                                <select asp-for="Academics[i].DocumentType"
                                        class="app-select">

                                    <option>Marksheet</option>
                                    <option>Degree Certificate</option>
                                    <option>Passing Certificate</option>
                                    <option>Other Academic Document</option>

                                </select>

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Upload Documents
                                </label>

                                <input asp-for="Academics[i].Documents"
                                       type="file"
                                       multiple
                                       accept=".pdf,.jpg,.jpeg,.png"
                                       class="form-control" />

                            </div>

                            <div class="form-group">

                                <label>
                                    <input asp-for="Academics[i].IsHighestQualification"
                                           type="checkbox" />

                                    Highest Qualification
                                </label>

                            </div>

                        </div>

                        <button type="button"
                                class="btn-app btn-danger-app remove-academic mt-1">

                            Remove

                        </button>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="app-card">
        <div class="card-body">
            <button type="submit" class="btn-app btn-primary-app">
                Save Employee
            </button>

            <a asp-action="Index" class="btn-app btn-secondary-app">
                Cancel
            </a>
        </div>
    </div>

</form>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const departmentDropdown = document.getElementById("departmentDropdown");
        const designationDropdown = document.getElementById("designationDropdown");
        const selectedDesignationId = @currentDesignationId;

        async function loadDesignations(departmentId, selectedId = 0) {
            designationDropdown.innerHTML =
                '<option value="">Select Designation</option>';

            if (!departmentId) {
                return;
            }

            try {
                const response = await fetch(
                    `/Employee/GetDesignations?departmentId=${departmentId}`
                );

                if (!response.ok) {
                    throw new Error("Unable to load designations.");
                }

                const data = await response.json();

                data.forEach(function (designation) {
                    const option = document.createElement("option");
                    option.value = designation.id;
                    option.textContent = designation.designationName;
                    option.selected = Number(designation.id) === Number(selectedId);
                    designationDropdown.appendChild(option);
                });
            }
            catch (error) {
                console.error(error);
            }
        }

        departmentDropdown.addEventListener("change", function () {
            loadDesignations(this.value);
        });

        if (departmentDropdown.value) {
            loadDesignations(
                departmentDropdown.value,
                selectedDesignationId
            );
        }
    });
</script>

<script>
    let academicIndex = @Model.Academics.Count;

    document.getElementById('addAcademic')
        .addEventListener('click', function () {

            const container =
                document.getElementById('academicContainer');

            const index = academicIndex++;

            const html = `
                <div class="academic-item border rounded p-3 mb-3">

                    <input type="hidden"
                           name="Academics.Index"
                           value="${index}" />

                    <div class="form-grid-2">

                        <div class="form-group">
                            <label class="form-label">Qualification Level</label>
                            <select name="Academics[${index}].QualificationLevel"
                                    class="app-select">
                                <option value="">Select Qualification</option>
                                <option>10th</option>
                                <option>12th</option>
                                <option>Diploma</option>
                                <option>Graduation</option>
                                <option>Post Graduation</option>
                                <option>Doctorate</option>
                                <option>Certification</option>
                                <option>Other</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Course Name</label>
                            <input name="Academics[${index}].CourseName"
                                   class="app-input" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Institute</label>
                            <input name="Academics[${index}].InstituteName"
                                   class="app-input" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Passing Year</label>
                            <input name="Academics[${index}].PassingYear"
                                   type="number"
                                   class="app-input" />
                        </div>

                        <div class="form-group">
                            <label class="form-label">Document Type</label>
                            <select name="Academics[${index}].DocumentType"
                                    class="app-select">
                                <option>Marksheet</option>
                                <option>Degree Certificate</option>
                                <option>Passing Certificate</option>
                                <option>Other Academic Document</option>
                            </select>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Documents</label>
                            <input name="Academics[${index}].Documents"
                                   type="file"
                                   multiple
                                   accept=".pdf,.jpg,.jpeg,.png"
                                   class="form-control" />
                        </div>

                    </div>

                    <button type="button"
                            class="btn-app btn-danger-app remove-academic">
                        Remove
                    </button>

                </div>`;

            container.insertAdjacentHTML(
                'beforeend',
                html);
        });

    document.addEventListener('click', function (event) {

        if (event.target.closest('.remove-academic')) {

            const items =
                document.querySelectorAll('.academic-item');

            if (items.length > 1) {
                event.target.closest('.academic-item').remove();
            }
        }
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", async function () {
        const currentPermanentCity =
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentPermanentCity));
        const currentPermanentPin =
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentPermanentPin));
        const currentLocalCity =
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentLocalCity));
        const currentLocalPin =
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(currentLocalPin));

        async function loadCities(stateDropdown, cityDropdown, selectedCity = "") {
            cityDropdown.innerHTML = '<option value="">Select City</option>';
            cityDropdown.disabled = true;

            const selectedState =
                stateDropdown.options[stateDropdown.selectedIndex];
            const stateId = selectedState?.dataset.stateId;

            if (!stateId) {
                return;
            }

            const response = await fetch(
                `/Location/GetCities?stateId=${stateId}`
            );

            if (!response.ok) {
                throw new Error("Unable to load cities.");
            }

            const cities = await response.json();

            cities.forEach(city => {
                const option = document.createElement("option");
                option.value = city.name;
                option.textContent = city.name;
                option.dataset.cityId = city.id;
                option.selected = city.name === selectedCity;
                cityDropdown.appendChild(option);
            });

            cityDropdown.disabled = false;
        }

        async function loadPincodes(cityDropdown, pinList, pinInput, selectedPin = "") {
            pinList.innerHTML = "";

            const selectedCity =
                cityDropdown.options[cityDropdown.selectedIndex];
            const cityId = selectedCity?.dataset.cityId;

            if (!cityId) {
                if (selectedPin) {
                    pinInput.value = selectedPin;
                }
                return;
            }

            const response = await fetch(
                `/Location/GetPincodes?cityId=${cityId}`
            );

            if (!response.ok) {
                throw new Error("Unable to load PIN codes.");
            }

            const pincodes = await response.json();

            pincodes.forEach(pin => {
                const option = document.createElement("option");
                option.value = pin.value;
                option.label = pin.text;
                pinList.appendChild(option);
            });

            if (selectedPin) {
                pinInput.value = selectedPin;
            }
        }

        function setupLocationSection(stateDropdown, cityDropdown, pinInput, pinList) {
            stateDropdown.addEventListener("change", async function () {
                cityDropdown.innerHTML = '<option value="">Select City</option>';
                cityDropdown.disabled = true;
                pinList.innerHTML = "";
                pinInput.value = "";

                try {
                    await loadCities(stateDropdown, cityDropdown);
                }
                catch (error) {
                    console.error(error);
                    alert("Cities could not be loaded.");
                }
            });

            cityDropdown.addEventListener("change", async function () {
                pinList.innerHTML = "";
                pinInput.value = "";

                try {
                    await loadPincodes(cityDropdown, pinList, pinInput);
                }
                catch (error) {
                    console.error(error);
                    alert("PIN codes could not be loaded.");
                }
            });

            pinInput.addEventListener("input", function () {
                this.value = this.value.replace(/\D/g, "").slice(0, 6);
            });
        }

        const permanentAddress = document.getElementById("permanentAddress");
        const permanentState = document.getElementById("permanentStateDropdown");
        const permanentCity = document.getElementById("permanentCityDropdown");
        const permanentPin = document.getElementById("permanentPinCodeInput");
        const permanentPinList = document.getElementById("permanentPinCodeOptions");

        const localAddress = document.getElementById("localAddress");
        const localState = document.getElementById("localStateDropdown");
        const localCity = document.getElementById("localCityDropdown");
        const localPin = document.getElementById("localPinCodeInput");
        const localPinList = document.getElementById("localPinCodeOptions");

        setupLocationSection(
            permanentState,
            permanentCity,
            permanentPin,
            permanentPinList
        );

        setupLocationSection(
            localState,
            localCity,
            localPin,
            localPinList
        );

        try {
            if (permanentState.value) {
                await loadCities(
                    permanentState,
                    permanentCity,
                    currentPermanentCity
                );
                await loadPincodes(
                    permanentCity,
                    permanentPinList,
                    permanentPin,
                    currentPermanentPin
                );
            }

            if (localState.value) {
                await loadCities(
                    localState,
                    localCity,
                    currentLocalCity
                );
                await loadPincodes(
                    localCity,
                    localPinList,
                    localPin,
                    currentLocalPin
                );
            }
        }
        catch (error) {
            console.error("Saved address values could not be restored.", error);
        }

        document.getElementById("sameAsPermanent")
            .addEventListener("change", async function () {
                if (!this.checked) {
                    return;
                }

                localAddress.value = permanentAddress.value;
                localState.value = permanentState.value;

                try {
                    await loadCities(
                        localState,
                        localCity,
                        permanentCity.value
                    );

                    await loadPincodes(
                        localCity,
                        localPinList,
                        localPin,
                        permanentPin.value
                    );
                }
                catch (error) {
                    console.error(error);
                    alert("The permanent address could not be copied completely.");
                }
            });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        const maxFileSize =
            5 * 1024 * 1024;

        document
            .querySelectorAll(".document-pdf-input")
            .forEach(function (input) {

                input.addEventListener(
                    "change",
                    function () {

                        const file = this.files[0];

                        if (!file) {
                            return;
                        }

                        const extension =
                            file.name
                                .split(".")
                                .pop()
                                .toLowerCase();

                        if (extension !== "pdf") {
                            alert(
                                "Only PDF documents are allowed."
                            );

                            this.value = "";
                            return;
                        }

                        if (file.size > maxFileSize) {
                            alert(
                                "Document size cannot exceed 5 MB."
                            );

                            this.value = "";
                        }
                    }
                );
            });
    });
</script>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}
