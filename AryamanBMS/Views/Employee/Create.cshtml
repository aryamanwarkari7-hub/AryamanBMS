@model AryamanBMS.Models.EmployeeModel

<div class="module-header">

    <div>
        <h1 class="module-title">Add Employee</h1>
        <p class="module-subtitle">Create a new employee</p>
    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">
                        Employee Code
                    </label>

                    <input asp-for="EmployeeCode"
                           class="app-input"
                           placeholder="Enter employee code" />
                    <span asp-validation-for="EmployeeCode"
                          class="text-danger">
                    </span>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        First Name
                    </label>

                    <input asp-for="FirstName"
                           class="app-input"
                           placeholder="Enter first name" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Last Name
                    </label>

                    <input asp-for="LastName"
                           class="app-input"
                           placeholder="Enter last name" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Joining Date
                    </label>

                    <input asp-for="JoiningDate"
                           type="date"
                           class="app-input" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Department
                    </label>

                    <select asp-for="DepartmentId"
                            id="departmentDropdown"
                            class="app-select">

                        <option value="">
                            Select Department
                        </option>

                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.Id">
                                @department.DepartmentName
                            </option>
                        }

                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Designation
                    </label>

                    <select asp-for="DesignationId"
                            id="designationDropdown"
                            class="app-select">

                        <option value="">
                            Select Designation
                        </option>

                    </select>
                </div>

                <div class="col-md-6 mb-3">

                    <label class="form-label">
                        System User
                    </label>

                    <select asp-for="ApplicationUserId"
                            class="app-select">

                        <option value="">
                            Select User
                        </option>

                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Id">
                                @user.FullName (@user.UserName)
                            </option>
                        }

                    </select>

                    <span asp-validation-for="ApplicationUserId"
                          class="text-danger">
                    </span>

                </div>

                <div class="form-group">
                    <label class="form-label">
                        Email
                    </label>

                    <input asp-for="Email"
                           type="email"
                           class="app-input"
                           placeholder="Enter email" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Mobile Number
                    </label>

                    <input asp-for="MobileNumber"
                           class="app-input"
                           placeholder="Enter mobile number" />
                </div>

                <div class="form-group">
                    <label class="form-label">
                        Status
                    </label>

                    <select asp-for="IsActive"
                            class="app-select">

                        <option value="true">
                            Active
                        </option>

                        <option value="false">
                            Inactive
                        </option>

                    </select>
                </div>

            </div>

            <div class="mt-4">

                <button type="submit"
                        class="btn-app btn-primary-app">
                    Save
                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>
<script>

    function loadDesignations(departmentId, selectedDesignationId = null)
    {
        fetch('/Employee/GetDesignations?departmentId=' + departmentId)
            .then(response => response.json())
            .then(data =>
            {
                let dropdown =
                    document.getElementById('designationDropdown');

                dropdown.innerHTML =
                    '<option value="">Select Designation</option>';

                data.forEach(function (designation)
                {
                    let selected =
                        designation.id == selectedDesignationId
                        ? 'selected'
                        : '';

                    dropdown.innerHTML +=
                        `<option value="${designation.id}" ${selected}>
                            ${designation.designationName}
                        </option>`;
                });
            });
    }

        document.getElementById('departmentDropdown')
        .addEventListener('change', function ()
    {
        fetch('/Employee/GetDesignations?departmentId=' + this.value)

            .then(response => response.json())

            .then(data =>
            {
                let dropdown =
                    document.getElementById('designationDropdown');

                dropdown.innerHTML =
                    '<option value="">Select Designation</option>';

                data.forEach(function (designation)
                {
                    dropdown.innerHTML +=
                        `<option value="${designation.id}">
                            ${designation.designationName}
                        </option>`;
                });
            });
    });
</script>