@model EmployeeFormViewModel
@{
    string currentPermanentCity = Model.Employee.City ?? string.Empty;
    string currentPermanentPin = Model.Employee.PinCode ?? string.Empty;
    string currentLocalCity = Model.Employee.LocalCity ?? string.Empty;
    string currentLocalPin = Model.Employee.LocalPinCode ?? string.Empty;
    int currentDesignationId = Model.Employee.DesignationId;
}

<div class="module-header">
    <div>
        <h1 class="module-title">Add Employee</h1>
        <p class="module-subtitle">Create a new employee</p>
    </div>
</div>


<form asp-action="Create"
      method="post"
      enctype="multipart/form-data">

    @if (!ViewData.ModelState.IsValid)
    {
        <div asp-validation-summary="ModelOnly"
             class="app-alert app-alert-danger mb-3">
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="app-alert app-alert-warning mb-3">
            Newly selected files are cleared after a validation error.
            Please select them again. Existing saved documents remain available.
        </div>
    }


    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Basic Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Employee Code</label>
                    <input asp-for="Employee.EmployeeCode" class="app-input" />
                    <span asp-validation-for="Employee.EmployeeCode" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Gender</label>
                    <select asp-for="Employee.Gender" class="app-select">
                        <option value="">Select Gender</option>
                        <option>Male</option>
                        <option>Female</option>
                        <option>Other</option>
                    </select>
                    <span asp-validation-for="Employee.Gender"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">First Name</label>
                    <input asp-for="Employee.FirstName" class="app-input" />
                    <span asp-validation-for="Employee.FirstName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Middle Name</label>

                    <input asp-for="Employee.MiddleName"
                           class="app-input" />

                    <span asp-validation-for="Employee.MiddleName"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Last Name</label>
                    <input asp-for="Employee.LastName" class="app-input" />
                    <span asp-validation-for="Employee.LastName" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Date Of Birth</label>
                    <input asp-for="Employee.DateOfBirth" type="date" class="app-input" />
                    <span asp-validation-for="Employee.DateOfBirth" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Employment Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Joining Date</label>
                    <input asp-for="Employee.JoiningDate" type="date" class="app-input" />
                    <span asp-validation-for="Employee.JoiningDate"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Employment Type</label>
                    <select asp-for="Employee.EmploymentType" class="app-select">
                        <option value="">Select Type</option>
                        <option>Permanent</option>
                        <option>Contract</option>
                        <option>Intern</option>
                        <option>Consultant</option>
                    </select>
                    <span asp-validation-for="Employee.EmploymentType"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Department</label>
                    <select asp-for="Employee.DepartmentId" id="departmentDropdown" class="app-select">
                        <option value="">Select Department</option>
                        @foreach (var department in ViewBag.Departments)
                        {
                            <option value="@department.Id">
                                @department.DepartmentName
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.DepartmentId"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Designation</label>
                    <select asp-for="Employee.DesignationId"
                            id="designationDropdown"
                            class="app-select"
                            data-selected-designation-id="@currentDesignationId">
                        <option value="">Select Designation</option>
                    </select>
                    <span asp-validation-for="Employee.DesignationId"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">System User</label>
                    <select asp-for="Employee.ApplicationUserId" class="app-select">
                        <option value="">Select User</option>
                        @foreach (var user in ViewBag.Users)
                        {
                            <option value="@user.Id">
                                @user.FullName (@user.UserName)
                            </option>
                        }
                    </select>
                    <span asp-validation-for="Employee.ApplicationUserId" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Employee.IsActive" class="app-select">
                        <option value="true">Active</option>
                        <option value="false">Inactive</option>
                    </select>
                    <span asp-validation-for="Employee.IsActive"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Contact Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Mobile Number</label>
                    <input asp-for="Employee.MobileNumber" class="app-input" />
                    <span asp-validation-for="Employee.MobileNumber" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Personal Email</label>
                    <input asp-for="Employee.PersonalEmail" type="email" class="app-input" />
                    <span asp-validation-for="Employee.PersonalEmail" class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Official Email</label>
                    <input asp-for="Employee.OfficialEmail" type="email" class="app-input" />
                    <span asp-validation-for="Employee.OfficialEmail" class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Address Information</h5>
        </div>

        <div class="card-body">

            <h6 class="mb-3">Permanent Address</h6>

            <div class="row g-3">

                <div class="col-md-12">

                    <label asp-for="Employee.PermanentAddress"
                           class="form-label">
                        Permanent Address
                    </label>

                    <textarea asp-for="Employee.PermanentAddress"
                              id="permanentAddress"
                              class="app-textarea"
                              rows="3"></textarea>

                    <span asp-validation-for="Employee.PermanentAddress"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.State"
                           class="form-label">
                        Permanent State
                    </label>

                    <select asp-for="Employee.State"
                            id="permanentStateDropdown"
                            class="app-select">

                        <option value="">Select State</option>

                        @foreach (var state in ViewBag.States)
                        {
                            <option value="@state.StateName"
                                    data-state-id="@state.Id">
                                @state.StateName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="Employee.State"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.City"
                           class="form-label">
                        Permanent City
                    </label>

                    <select asp-for="Employee.City"
                            id="permanentCityDropdown"
                            class="app-select"
                            disabled>

                        <option value="">Select City</option>

                    </select>

                    <span asp-validation-for="Employee.City"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.PinCode"
                           class="form-label">
                        Permanent PIN Code
                    </label>

                    <input asp-for="Employee.PinCode"
                           id="permanentPinCodeInput"
                           list="permanentPinCodeOptions"
                           class="app-input"
                           maxlength="6"
                           inputmode="numeric"
                           placeholder="Select or type PIN code" />

                    <datalist id="permanentPinCodeOptions"></datalist>

                    <span asp-validation-for="Employee.PinCode"
                          class="validation-message"></span>

                </div>

            </div>

            <hr class="my-4" />

            <div class="d-flex align-items-center gap-2 mb-3">

                <input type="checkbox"
                       id="sameAsPermanent"
                       class="form-check-input" />

                <label for="sameAsPermanent"
                       class="form-check-label">

                    Local address is same as permanent address

                </label>

            </div>

            <h6 class="mb-3">Local Address</h6>

            <div class="row g-3">

                <div class="col-md-12">

                    <label asp-for="Employee.LocalAddress"
                           class="form-label">
                        Local Address
                    </label>

                    <textarea asp-for="Employee.LocalAddress"
                              id="localAddress"
                              class="app-textarea"
                              rows="3"></textarea>

                    <span asp-validation-for="Employee.LocalAddress"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalState"
                           class="form-label">
                        Local State
                    </label>

                    <select asp-for="Employee.LocalState"
                            id="localStateDropdown"
                            class="app-select">

                        <option value="">Select State</option>

                        @foreach (var state in ViewBag.States)
                        {
                            <option value="@state.StateName"
                                    data-state-id="@state.Id">
                                @state.StateName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="Employee.LocalState"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalCity"
                           class="form-label">
                        Local City
                    </label>

                    <select asp-for="Employee.LocalCity"
                            id="localCityDropdown"
                            class="app-select"
                            disabled>

                        <option value="">Select City</option>

                    </select>

                    <span asp-validation-for="Employee.LocalCity"
                          class="validation-message"></span>

                </div>

                <div class="col-md-4">

                    <label asp-for="Employee.LocalPinCode"
                           class="form-label">
                        Local PIN Code
                    </label>

                    <input asp-for="Employee.LocalPinCode"
                           id="localPinCodeInput"
                           list="localPinCodeOptions"
                           class="app-input"
                           maxlength="6"
                           inputmode="numeric"
                           placeholder="Select or type PIN code" />

                    <datalist id="localPinCodeOptions"></datalist>

                    <span asp-validation-for="Employee.LocalPinCode"
                          class="validation-message"></span>

                </div>

            </div>

        </div>

    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Emergency Contact</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Emergency Contact Name</label>
                    <input asp-for="Employee.EmergencyContact" class="app-input" />
                    <span asp-validation-for="Employee.EmergencyContact"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Emergency Contact Number</label>
                    <input asp-for="Employee.EmergencyPhone" class="app-input" />
                    <span asp-validation-for="Employee.EmergencyPhone"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">
        <div class="card-header">
            <h5 class="card-title">Statutory Information</h5>
        </div>

        <div class="card-body">
            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Aadhaar Number</label>
                    <input asp-for="Employee.AadhaarNo"
                           class="app-input"
                           maxlength="12"
                           inputmode="numeric"
                           placeholder="Enter 12-digit Aadhaar number" />
                    <span asp-validation-for="Employee.AadhaarNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">PAN Number</label>
                    <input asp-for="Employee.PanNo"
                           class="app-input"
                           maxlength="10"
                           placeholder="Enter 10-character PAN number" />
                    <span asp-validation-for="Employee.PanNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">UAN Number</label>
                    <input asp-for="Employee.UanNo"
                           class="app-input"
                           maxlength="12"
                           inputmode="numeric"
                           placeholder="Enter 12-digit UAN number" />
                    <span asp-validation-for="Employee.UanNo"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">ESIC Number</label>

                    <input asp-for="Employee.EsicNo"
                           class="app-input"
                           maxlength="10"
                           inputmode="numeric"
                           pattern="[0-9]{10}"
                           placeholder="Enter 10-digit ESIC number" />

                    <span asp-validation-for="Employee.EsicNo"
                          class="validation-message"></span>
                </div>

            </div>
        </div>
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Statutory Documents</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                @for (int i = 0;
                                i < Model.StatutoryDocuments.Count;
                                i++)
                {
                    <div class="form-group">

                        <input asp-for="StatutoryDocuments[i].DocumentType"
                               type="hidden" />

                        <label class="form-label">
                            @Model.StatutoryDocuments[i].DocumentType
                        </label>

                        <input asp-for="StatutoryDocuments[i].File"
                               type="file"
                               accept=".pdf,application/pdf"
                               class="form-control document-pdf-input" />

                        <span asp-validation-for="StatutoryDocuments[i].File"
                              class="validation-message"></span>

                        <small class="text-muted">
                            PDF only. Maximum size: 5 MB.
                        </small>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Joining Documents</h5>
        </div>

        <div class="card-body">

            @for (int i = 0;
                        i < Model.JoiningDocuments.Count;
                        i++)
            {
                <div class="row align-items-center
                            border-bottom py-3">

                    <div class="col-md-4">

                        <input asp-for="JoiningDocuments[i].DocumentType"
                               type="hidden" />

                        <label class="form-label mb-0">
                            @Model.JoiningDocuments[i].DocumentType
                        </label>

                    </div>

                    <div class="col-md-8">

                        <input asp-for="JoiningDocuments[i].File"
                               type="file"
                               accept=".pdf,application/pdf"
                               class="form-control document-pdf-input" />

                        <span asp-validation-for="JoiningDocuments[i].File"
                              class="validation-message"></span>

                    </div>

                </div>
            }

            <small class="text-muted d-block mt-3">
                Upload PDF files only. Maximum size: 5 MB per document.
            </small>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="card-title">Previous Employment</h5>

            <button type="button"
                    id="addPreviousEmployment"
                    data-initial-index="@Model.PreviousEmployments.Count"
                    class="btn-app btn-primary-app">
                <i class="bi bi-plus-lg"></i>
                Add Previous Employment
            </button>
        </div>

        <div class="card-body">

            <div id="previousEmploymentContainer">

                @for (int i = 0; i < Model.PreviousEmployments.Count; i++)
                {
                    <div class="previous-employment-item border rounded p-3 mb-3">

                        <input type="hidden"
                               name="PreviousEmployments.Index"
                               value="@i" />

                        <div class="form-grid-2">

                            <div class="form-group">
                                <label class="form-label">Company Name</label>

                                <input asp-for="PreviousEmployments[i].CompanyName"
                                       class="app-input" />

                                <span asp-validation-for="PreviousEmployments[i].CompanyName"
                                      class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Designation</label>

                                <input asp-for="PreviousEmployments[i].Designation"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Department</label>

                                <input asp-for="PreviousEmployments[i].Department"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Employment Type</label>

                                <select asp-for="PreviousEmployments[i].EmploymentType"
                                        class="app-select">
                                    <option value="">Select Employment Type</option>
                                    <option value="Permanent">Permanent</option>
                                    <option value="Contract">Contract</option>
                                    <option value="Intern">Intern</option>
                                    <option value="Consultant">Consultant</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Start Date</label>

                                <input asp-for="PreviousEmployments[i].StartDate"
                                       type="date"
                                       class="app-input" />

                                <span asp-validation-for="PreviousEmployments[i].StartDate"
                                      class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">End Date</label>

                                <input asp-for="PreviousEmployments[i].EndDate"
                                       type="date"
                                       class="app-input" />

                                <span asp-validation-for="PreviousEmployments[i].EndDate"
                                      class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Last Salary</label>

                                <input asp-for="PreviousEmployments[i].LastSalary"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Reason For Leaving</label>

                                <input asp-for="PreviousEmployments[i].ReasonForLeaving"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Company Website</label>

                                <input asp-for="PreviousEmployments[i].CompanyWebsite"
                                       type="url"
                                       class="app-input"
                                       placeholder="https://example.com" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Company Address</label>

                                <textarea asp-for="PreviousEmployments[i].CompanyAddress"
                                          class="app-textarea"
                                          rows="2"></textarea>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Company State</label>

                                <select asp-for="PreviousEmployments[i].CompanyState"
                                        class="app-select previous-company-state">
                                    <option value="">Select State</option>

                                    @foreach (var state in ViewBag.States)
                                    {
                                        <option value="@state.StateName"
                                                data-state-id="@state.Id">
                                            @state.StateName
                                        </option>
                                    }
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Company City</label>

                                <select asp-for="PreviousEmployments[i].CompanyCity"
                                        class="app-select previous-company-city"
                                        data-selected-city="@Model.PreviousEmployments[i].CompanyCity"
                                        disabled>
                                    <option value="">Select City</option>
                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Company PIN Code</label>

                                <input asp-for="PreviousEmployments[i].CompanyPinCode"
                                       maxlength="6"
                                       inputmode="numeric"
                                       class="app-input previous-company-pin" />
                            </div>

                        </div>

                        <h6 class="mt-4 mb-3">HR Contact Information</h6>

                        <div class="form-grid-2">

                            <div class="form-group">
                                <label class="form-label">HR Contact Name</label>

                                <input asp-for="PreviousEmployments[i].HRContactName"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">HR Contact Email</label>

                                <input asp-for="PreviousEmployments[i].HRContactEmail"
                                       type="email"
                                       class="app-input" />

                                <span asp-validation-for="PreviousEmployments[i].HRContactEmail"
                                      class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">HR Contact Number</label>

                                <input asp-for="PreviousEmployments[i].HRContactNumber"
                                       class="app-input"
                                       maxlength="20" />
                            </div>

                        </div>

                        <h6 class="mt-4 mb-3">Employment Documents</h6>

                        <div class="form-grid-2">

                            <div class="form-group">
                                <label class="form-label">Experience Letter</label>

                                <input asp-for="PreviousEmployments[i].ExperienceLetter"
                                       type="file"
                                       accept=".pdf,application/pdf"
                                       class="form-control" />

                                <span asp-validation-for="PreviousEmployments[i].ExperienceLetter"
                                      class="validation-message"></span>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Relieving Letter</label>

                                <input asp-for="PreviousEmployments[i].RelievingLetter"
                                       type="file"
                                       accept=".pdf,application/pdf"
                                       class="form-control" />

                                <span asp-validation-for="PreviousEmployments[i].RelievingLetter"
                                      class="validation-message"></span>
                            </div>

                        </div>

                        <button type="button"
                                class="btn-app btn-danger-app remove-previous-employment mt-3">
                            <i class="bi bi-trash"></i>
                            Remove
                        </button>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header d-flex justify-content-between">

            <h5 class="card-title">
                Academic Information
            </h5>

            <button type="button"
                    id="addAcademic"
                    data-initial-index="@Model.Academics.Count"
                    class="btn-app btn-primary-app">

                <i class="bi bi-plus-lg"></i>
                Add Qualification

            </button>

        </div>

        <div class="card-body">

            <div id="academicContainer">

                @for (int i = 0; i < Model.Academics.Count; i++)
                {
                    <div class="academic-item border rounded p-3 mb-3">

                        <input type="hidden"
                               name="Academics.Index"
                               value="@i" />

                        <div class="form-grid-2">

                            <div class="form-group">

                                <label class="form-label">
                                    Qualification Level
                                </label>

                                <select asp-for="Academics[i].QualificationLevel"
                                        class="app-select">

                                    <option value="">Select Qualification</option>
                                    <option>10th</option>
                                    <option>12th</option>
                                    <option>Diploma</option>
                                    <option>Graduation</option>
                                    <option>Post Graduation</option>
                                    <option>Doctorate</option>
                                    <option>Certification</option>
                                    <option>Other</option>

                                </select>

                            </div>

                            <div class="form-group">
                                <label class="form-label">Course Name</label>
                                <input asp-for="Academics[i].CourseName"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Specialization</label>
                                <input asp-for="Academics[i].Specialization"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Institute</label>
                                <input asp-for="Academics[i].InstituteName"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Board / University</label>
                                <input asp-for="Academics[i].BoardOrUniversity"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Passing Year</label>
                                <input asp-for="Academics[i].PassingYear"
                                       type="number"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Result Type</label>

                                <select asp-for="Academics[i].ResultType"
                                        class="app-select">

                                    <option value="">Select Result Type</option>
                                    <option>Percentage</option>
                                    <option>CGPA</option>
                                    <option>Grade</option>

                                </select>
                            </div>

                            <div class="form-group">
                                <label class="form-label">Score</label>
                                <input asp-for="Academics[i].Score"
                                       type="number"
                                       step="0.01"
                                       class="app-input" />
                            </div>

                            <div class="form-group">
                                <label class="form-label">Grade</label>
                                <input asp-for="Academics[i].Grade"
                                       class="app-input" />
                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Document Type
                                </label>

                                <select asp-for="Academics[i].DocumentType"
                                        class="app-select">

                                    <option>Marksheet</option>
                                    <option>Degree Certificate</option>
                                    <option>Passing Certificate</option>
                                    <option>Other Academic Document</option>

                                </select>

                            </div>

                            <div class="form-group">

                                <label class="form-label">
                                    Upload Documents
                                </label>

                                <input asp-for="Academics[i].Documents"
                                       type="file"
                                       multiple
                                       accept=".pdf,.jpg,.jpeg,.png"
                                       class="form-control" />

                            </div>

                            <div class="form-group">

                                <label>
                                    <input asp-for="Academics[i].IsHighestQualification"
                                           type="checkbox" />

                                    Highest Qualification
                                </label>

                            </div>

                        </div>

                        <button type="button"
                                class="btn-app btn-danger-app remove-academic mt-1">

                            Remove

                        </button>

                    </div>
                }

            </div>

        </div>

    </div>

    <div class="app-card">
        <div class="card-body">
            <button type="submit" class="btn-app btn-primary-app">
                Save Employee
            </button>

            <a asp-action="Index" class="btn-app btn-secondary-app">
                Cancel
            </a>
        </div>
    </div>

</form>

<div id="employeeAddressConfig"
     data-current-permanent-city="@currentPermanentCity"
     data-current-permanent-pin="@currentPermanentPin"
     data-current-local-city="@currentLocalCity"
     data-current-local-pin="@currentLocalPin">
</div>

<select id="companyStateOptionsTemplate" hidden>
    <option value="">Select State</option>

    @foreach (var state in ViewBag.States)
    {
        <option value="@state.StateName"
                data-state-id="@state.Id">
            @state.StateName
        </option>
    }
</select>





@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/employee-form.js" asp-append-version="true"></script>
    <script src="~/js/employee-create.js" asp-append-version="true"></script>
}