@model PagedListViewModel<AttendanceModel>

@{
    ViewData["Title"] = "Attendance Register";
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Attendance Register
        </h1>

        <p class="module-subtitle">
            Manage employee attendance records
        </p>
    </div>

    <div class="d-flex flex-wrap gap-2">

        <a asp-action="Create"
           class="btn-app btn-primary-app">

            <i class="bi bi-plus-circle"></i>
            Add Attendance

        </a>

        <a asp-action="Dashboard"
           class="btn-app btn-secondary-app">

            <i class="bi bi-grid"></i>
            Dashboard

        </a>

        <a asp-action="Summary"
           class="btn-app btn-secondary-app">

            <i class="bi bi-bar-chart"></i>
            Attendance Summary

        </a>

        <a asp-action="ExportExcel"
           asp-route-searchText="@ViewBag.SearchText"
           asp-route-fromDate="@ViewBag.FromDate"
           asp-route-toDate="@ViewBag.ToDate"
           class="btn-app btn-success-app">

            <i class="bi bi-file-earmark-excel"></i>
            Export Excel

        </a>

    </div>

</div>

<div class="app-card mb-3">

    <div class="card-body">

        <form asp-action="Register"
              method="get">

            <div class="d-flex flex-wrap gap-2">

                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="app-input flex-grow-1"
                       placeholder="Employee Code / Name / Mobile / Email"
                       autocomplete="off" />

                <input type="date"
                       name="fromDate"
                       value="@ViewBag.FromDate"
                       class="app-input" />

                <input type="date"
                       name="toDate"
                       value="@ViewBag.ToDate"
                       class="app-input" />

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Search

                </button>

                <a asp-action="Register"
                   class="btn-app btn-secondary-app">

                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset

                </a>

            </div>

        </form>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Attendance List
        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-calendar-x"></i>

                <p class="mb-0">
                    No attendance records found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Date</th>
                            <th>Employee Code</th>
                            <th>Employee Name</th>
                            <th>Status</th>
                            <th>Location</th>
                            <th>Working Hours</th>
                            <th>Remarks</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var attendance in Model.Items)
                        {
                            <tr>

                                <td>
                                    @attendance.Id
                                </td>

                                <td>
                                    @(attendance.AttendanceDate.ToString("dd-MMM-yyyy"))
                                </td>

                                <td>
                                    @(attendance.Employee?.EmployeeCode
                                      ?? "-")
                                </td>

                                <td>
                                    @(attendance.Employee?.FullName
                                      ?? "-")
                                </td>

                                <td>

                                    @switch (attendance.Status)
                                    {
                                        case "P":
                                            <span class="badge-success">
                                                Present
                                            </span>
                                            break;

                                        case "A":
                                            <span class="badge-danger">
                                                Absent
                                            </span>
                                            break;

                                        case "L":
                                            <span class="badge-warning">
                                                Leave
                                            </span>
                                            break;

                                        case "H":
                                            <span class="badge-primary">
                                                Holiday
                                            </span>
                                            break;

                                        case "WO":
                                            <span class="badge-secondary">
                                                Week Off
                                            </span>
                                            break;

                                        case "OD":
                                            <span class="badge-info">
                                                On Duty
                                            </span>
                                            break;

                                        default:
                                            <span>-</span>
                                            break;
                                    }

                                </td>

                                <td>
                                    @(attendance.LocationType ?? "-")
                                </td>

                                <td>
                                    @attendance.WorkingHours.ToString("0.00")
                                    hrs
                                </td>

                                <td>
                                    @(attendance.Remarks ?? "-")
                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Details"
                                           asp-route-id="@attendance.Id"
                                           class="btn-app btn-primary-app btn-icon"
                                           title="View attendance"
                                           aria-label="View attendance">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@attendance.Id"
                                           class="btn-app btn-secondary-app btn-icon"
                                           title="Edit attendance"
                                           aria-label="Edit attendance">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@attendance.Id"
                                           class="btn-app btn-danger-app btn-icon"
                                           title="Delete attendance"
                                           aria-label="Delete attendance">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>