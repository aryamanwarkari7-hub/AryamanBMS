@model AryamanBMS.ViewModels.AttendanceDashboardViewModel

@{
    ViewData["Title"] = "Attendance Dashboard";

    bool isDailyView =
        ViewBag.IsDailyView == true;

    DateTime? selectedDate =
        ViewBag.SelectedDate as DateTime?;

    var dailyAttendance =
        ViewBag.DailyAttendance
        as List<AryamanBMS.Models.AttendanceModel>
        ?? new List<AryamanBMS.Models.AttendanceModel>();
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Attendance Dashboard
        </h1>

        <p class="module-subtitle">
            Monthly Attendance Summary
        </p>
    </div>

    <div class="d-flex gap-2 mb-3">

        <a asp-action="Create"
           class="btn-app btn-primary-app">

            <i class="bi bi-plus-circle"></i>
            Add Attendance

        </a>
        

        <a asp-action="Register"
           class="btn-app btn-secondary-app">

            <i class="bi bi-table"></i>
            Attendance Register

        </a>

        <a asp-action="Summary"
           class="btn-app btn-secondary-app">

            <i class="bi bi-bar-chart"></i>
            Attendance Summary

        </a>

    </div>

</div>


<!-- Summary Cards -->

<div class="dashboard-grid">

    <div class="stats-card">

        <div class="stats-label">
            @(isDailyView
                        ? $"Present on {selectedDate:dd MMM yyyy}"
                        : "Present Today")
        </div>

        <div class="stats-number">
            @Model.PresentToday
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            @(isDailyView
                        ? $"On Leave on {selectedDate:dd MMM yyyy}"
                        : "On Leave Today")
        </div>

        <div class="stats-number">
            @Model.OnLeaveToday
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            @(isDailyView
                        ? $"Not Marked on {selectedDate:dd MMM yyyy}"
                        : "Not Marked Today")
        </div>

        <div class="stats-number">
            @Model.NotMarkedToday
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            Attendance %
        </div>

        <div class="stats-number">
            @Model.AttendancePercentage%
        </div>

    </div>

</div>


<!-- Filter Card -->

<div class="app-card mb-3">

    <div class="card-header">

        <h5 class="card-title">
            Attendance Filter
        </h5>

    </div>

    <div class="card-body">

        <form asp-action="Dashboard"
              method="get">

            <div class="filter-form-row">

                <div class="form-group">

                    <label class="form-label">
                        Day
                    </label>

                    <select name="day"
                            class="app-select">

                        <option value="">
                            All Days
                        </option>

                        @for (int calendarDay = 1;
                                                calendarDay <= Model.TotalDays;
                                                calendarDay++)
                        {
                            if (ViewBag.SelectedDay != null &&
                            calendarDay ==
                            (int)ViewBag.SelectedDay)
                            {
                                <option value="@calendarDay"
                                        selected>
                                    @calendarDay
                                </option>
                            }
                            else
                            {
                                <option value="@calendarDay">
                                    @calendarDay
                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="form-group">

                    <label class="form-label">
                        Month
                    </label>

                    <select name="month"
                            class="app-select">

                        @for (int month = 1; month <= 12; month++)
                        {
                            var monthName =
                                new DateTime(2000, month, 1)
                                .ToString("MMMM");

                            if (month == Model.Month)
                            {
                                <option value="@month" selected>
                                    @monthName
                                </option>
                            }
                            else
                            {
                                <option value="@month">
                                    @monthName
                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="form-group">

                    <label class="form-label">
                        Year
                    </label>

                    <select name="year"
                            class="app-select">

                        @for (int year = DateTime.Today.Year - 2;
                             year <= DateTime.Today.Year + 2;
                             year++)
                        {
                            if (year == Model.Year)
                            {
                                <option value="@year" selected>
                                    @year
                                </option>
                            }
                            else
                            {
                                <option value="@year">
                                    @year
                                </option>
                            }
                        }

                    </select>

                </div>

                <div class="filter-form-actions">
                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Load

                </button>
                </div>

            </div>

        </form>

    </div>

</div>

<!-- Legend -->

<div class="app-card mb-3">

    <div class="card-header">

        <h5 class="card-title">
            Attendance Legend
        </h5>

    </div>

    <div class="card-body">

        <div class="d-flex flex-wrap gap-2">

            <span class="badge-success">P - Present</span>

            <span class="badge-danger">A - Absent</span>

            <span class="badge-warning">L - Leave</span>

            <span class="badge-primary">H - Holiday</span>

            <span class="badge-secondary">WO - Week Off</span>

            <span class="badge-info">OD - On Duty</span>

        </div>

    </div>

</div>

<!-- Register -->
@if (isDailyView)
{
    <div class="app-card table-card">

        <div class="card-header">

            <h5 class="card-title">
                Daily Attendance -
                @selectedDate?.ToString("dd MMMM yyyy")
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Status</th>
                            <th>Check In</th>
                            <th>Check Out</th>
                            <th>Working Hours</th>
                            <th>Location</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var employee in Model.Employees)
                        {
                            var record =
                            dailyAttendance
                            .FirstOrDefault(a =>
                            a.EmployeeId ==
                            employee.EmployeeId);

                            <tr>

                                <td>
                                    <strong>
                                        @employee.EmployeeName
                                    </strong>

                                    <br />

                                    <small>
                                        @employee.EmployeeCode
                                    </small>
                                </td>

                                <td>
                                    @(record?.Status ?? "-")
                                </td>

                                <td>
                                    @(record?.CheckInTime
                                                                ?.ToString("hh:mm tt")
                                                                ?? "-")
                                                                   </td>

                                <td>
                                    @(record?.CheckOutTime
                                                                ?.ToString("hh:mm tt")
                                                                ?? "-")
                                                                   </td>

                                <td>
                                    @(record?.WorkingHours.ToString("0.##")
                                                                ?? "-")
                        </td>

                                <td>
                                    @(record?.LocationType ?? "-")
                                </td>

                                <td>
                                    @(record?.Remarks ?? "-")
                                </td>

                            </tr>
                                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>
}

@if (!isDailyView){
<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">

            Attendance Register
            -
            @Model.Month/@Model.Year

        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Employees.Any())
        {
            <div class="empty-state">
                No attendance records found.
            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table attendance-register">

                    <thead>

                        <tr>

                            <th>
                                Employee
                            </th>

                            @for (int day = 1;
                                day <= Model.TotalDays;
                                day++)
                            {
                                <th>
                                    @day
                                </th>
                            }

                            <th>P</th>
                            <th>A</th>
                            <th>L</th>
                            <th>H</th>
                            <th>WO</th>
                            <th>OD</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var employee in Model.Employees)
                        {
                            <tr>

                                <td style="min-width:240px;">

                                    <strong>
                                        @employee.EmployeeName
                                    </strong>

                                    <br />

                                    <small>
                                        @employee.EmployeeCode
                                    </small>

                                </td>

                                @for (int day = 1;
                                    day <= Model.TotalDays;
                                    day++)
                                {
                                    var status =
                                        employee.DailyStatus.ContainsKey(day)
                                        ? employee.DailyStatus[day]
                                        : "";

                                    <td>

                                        @switch (status)
                                        {
                                            case "P":
                                                <span class="badge-success">P</span>
                                                break;

                                            case "A":
                                                <span class="badge-danger">A</span>
                                                break;

                                            case "L":
                                                <span class="badge-warning">L</span>
                                                break;

                                            case "H":
                                                <span class="badge-primary">H</span>
                                                break;

                                            case "WO":
                                                <span class="badge-secondary">WO</span>
                                                break;

                                            case "OD":
                                                <span class="badge-info">OD</span>
                                                break;

                                            default:
                                                <span>-</span>
                                                break;
                                        }

                                    </td>
                                }

                                <td><strong>@employee.PresentCount</strong></td>
                                <td><strong>@employee.AbsentCount</strong></td>
                                <td><strong>@employee.LeaveCount</strong></td>
                                <td><strong>@employee.HolidayCount</strong></td>
                                <td><strong>@employee.WeekOffCount</strong></td>
                                <td><strong>@employee.OnDutyCount</strong></td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

    </div>

</div>
}