@model AryamanBMS.Models.AttendanceModel

<div class="module-header">

    <div>
        <h1 class="module-title">Delete Attendance</h1>
        <p class="module-subtitle">
            Confirm attendance deletion
        </p>
    </div>

</div>

<div class="app-card">

    <div class="card-body">

        <div class="form-grid-2">

            <div class="form-group">

                <label class="form-label">
                    Employee Code
                </label>

                <input value="@Model.Employee?.EmployeeCode"
                       class="app-input"
                       readonly />

            </div>

            <div class="form-group">

                <label class="form-label">
                    Employee Name
                </label>

                <input value="@Model.Employee?.FullName"
                       class="app-input"
                       readonly />

            </div>

            <div class="form-group">

                <label class="form-label">
                    Attendance Date
                </label>

                <input value="@Model.AttendanceDate.ToString("dd-MMM-yyyy")"
                       class="app-input"
                       readonly />

            </div>

            <div class="form-group">

                <label class="form-label">
                    Status
                </label>

                <input value="@Model.Status"
                       class="app-input"
                       readonly />

            </div>

            <div class="form-group">

                <label class="form-label">
                    Remarks
                </label>

                <textarea class="app-textarea"
                          readonly>@Model.Remarks</textarea>

            </div>

        </div>

        <div class="mt-4">

            <form asp-action="DeleteConfirmed"
                  method="post">

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn-app btn-danger-app">

                    Delete

                </button>

                <a asp-action="Register"
                   class="btn-app btn-secondary-app">

                    Cancel

                </a>

            </form>

        </div>

    </div>

</div>