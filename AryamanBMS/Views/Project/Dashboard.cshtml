@model AryamanBMS.ViewModels.ProjectDashboardViewModel

@using System.Globalization

@{
    ViewData["Title"] = "Project Workspace";
}

<div class="module-header">

    <div>

        <h1 class="module-title">
            Project Workspace
        </h1>

        <p class="module-subtitle">
            @Model.Project.ProjectCode -
            @Model.Project.ProjectName
        </p>

    </div>

    <div class="module-header-actions">

        <a asp-action="Details"
           asp-route-id="@Model.Project.Id"
           class="btn-app btn-secondary-app">
            <i class="bi bi-eye"></i>
            Details
        </a>

        <a asp-controller="ProjectTask"
           asp-action="Index"
           asp-route-projectId="@Model.Project.Id"
           class="btn-app btn-primary-app">
            <i class="bi bi-list-task"></i>
            Tasks
        </a>

        <a asp-controller="ProjectMember"
           asp-action="AllMembers"
           asp-route-projectId="@Model.Project.Id"
           class="btn-app btn-secondary-app">
            <i class="bi bi-people"></i>
            Project Members
        </a>

        <a asp-controller="ProjectFlow"
           asp-action="Index"
           asp-route-projectId="@Model.Project.Id"
           class="btn-app btn-secondary-app">
            <i class="bi bi-diagram-3"></i>
            Milestones
        </a>

        <div class="dropdown">
            <button type="button"
                    class="btn-app btn-secondary-app dropdown-toggle"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                <i class="bi bi-three-dots"></i>
                More
            </button>

            <div class="dropdown-menu dropdown-menu-end">

                <a asp-controller="TaskTracker"
                   asp-action="Index"
                   asp-route-projectId="@Model.Project.Id"
                   class="dropdown-item">
                    <i class="bi bi-activity"></i>
                    Task Updates
                </a>

                <a asp-controller="MOM"
                   asp-action="Index"
                   asp-route-projectId="@Model.Project.Id"
                   class="dropdown-item">
                    <i class="bi bi-journal-text"></i>
                    Meetings / MOM
                </a>

                <a asp-controller="Risk"
                   asp-action="Index"
                   asp-route-projectId="@Model.Project.Id"
                   class="dropdown-item">
                    <i class="bi bi-exclamation-triangle"></i>
                    Risk Register
                </a>

                <a asp-controller="ProjectTimeline"
                   asp-action="Index"
                   asp-route-projectId="@Model.Project.Id"
                   class="dropdown-item">
                    <i class="bi bi-clock-history"></i>
                    Activity Timeline
                </a>

            </div>
        </div>

    </div>

</div>

<!-- ==========================================
     PROJECT SUMMARY CARDS
=========================================== -->

<div class="dashboard-grid">

    <div class="stats-card">

        <div class="stats-label">
            Health Status
        </div>

        @{
            string healthClass =
            Model.ProjectHealth == "Critical"
            ? "badge-danger"
            : Model.ProjectHealth == "Warning"
            ? "badge-warning"
            : "badge-success";
        }

        <div class="stats-number">
            <span class="@healthClass">
                @Model.ProjectHealth
            </span>
        </div>

        <small class="text-muted d-block mt-2">
            @Model.ProjectHealthMessage
        </small>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            Overall Progress
        </div>

        <div class="stats-number">
            @Model.OverallProgress.ToString("0.##")%
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            Active Members
        </div>

        <div class="stats-number">
            @Model.ActiveMemberCount
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            Open Risks
        </div>

        <div class="stats-number">
            @Model.OpenRiskCount
        </div>

    </div>

    <div class="stats-card">

        <div class="stats-label">
            Overdue Tasks
        </div>

        <div class="stats-number">
            @Model.OverdueTaskCount
        </div>

    </div>

</div>
<!-- ==========================================
     PROJECT GANTT CHART
=========================================== -->

<div class="app-card table-card mb-4">

    <div class="card-header">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">

            <h5 class="card-title">
                Project Gantt Chart
            </h5>

            @if (Model.Gantt.Tasks.Any())
            {
                <div class="gantt-project-summary">

                    <div>
                        <strong>Project Manager:</strong>
                        @Model.Gantt.ProjectManagerName
                    </div>

                    <div>
                        <strong>Timeline:</strong>

                        @Model.Gantt.TimelineStart.ToString("dd MMM yyyy")
                        -
                        @Model.Gantt.TimelineEnd.ToString("dd MMM yyyy")
                    </div>

                    <div>
                        <strong>Tasks:</strong>
                        @Model.Gantt.Tasks.Count
                    </div>

                    <div>
                        <strong>Overall Progress:</strong>
                        @Model.OverallProgress.ToString("0.##")%
                    </div>

                </div>
            }

        </div>

    </div>

    <div class="card-body">

        @if (!Model.Gantt.Tasks.Any())
        {
            <div class="empty-state">

                <i class="bi bi-bar-chart-steps"></i>

                <p class="mb-0">
                    No tasks with valid start and due dates are available.
                </p>

            </div>
        }
        else
        {
            <!-- Status Legend -->

            <div class="gantt-legend">

                <span class="gantt-legend-item gantt-legend-not-started">
                    Not Started
                </span>

                <span class="gantt-legend-item gantt-legend-in-progress">
                    In Progress
                </span>

                <span class="gantt-legend-item gantt-legend-completed">
                    Completed
                </span>

                <span class="gantt-legend-item gantt-legend-overdue">
                    Overdue
                </span>

                <span class="gantt-legend-item gantt-legend-on-hold">
                    On Hold
                </span>

            </div>

            <div class="gantt-wrapper">

                <!-- Gantt Header -->

                <div class="gantt-header-row">

                    <div class="gantt-task-column">
                        Task Details
                    </div>

                    <div class="gantt-timeline-header">

                        @foreach (var dateItem in Model.Gantt.TimelineDates)
                        {
                            string datePosition =
                            dateItem.PositionPercent.ToString(
                            "0.##",
                            CultureInfo.InvariantCulture);

                            <span class="gantt-date-label"
                                  style="left: @datePosition%;">

                                @dateItem.Date.ToString("dd MMM")

                            </span>
                        }

                    </div>

                </div>

                
                <!-- Gantt Rows -->
                @for (int taskIndex = 0;
                            taskIndex < Model.Gantt.Tasks.Count;
                            taskIndex++)
                {
                    var task = Model.Gantt.Tasks[taskIndex];

                    string leftPercent =
                    task.LeftPercent.ToString(
                    "0.##",
                    CultureInfo.InvariantCulture);

                    string widthPercent =
                    task.WidthPercent.ToString(
                    "0.##",
                    CultureInfo.InvariantCulture);

                    string taskClass;

                    if (task.IsOverdue)
                    {
                        taskClass = "gantt-bar-overdue";
                    }
                    else if (string.Equals(
                    task.Status,
                    "Completed",
                    StringComparison.OrdinalIgnoreCase))
                    {
                        taskClass = "gantt-bar-completed";
                    }
                    else if (string.Equals(
                    task.Status,
                    "In Progress",
                    StringComparison.OrdinalIgnoreCase))
                    {
                        taskClass = "gantt-bar-in-progress";
                    }
                    else if (string.Equals(
                    task.Status,
                    "On Hold",
                    StringComparison.OrdinalIgnoreCase))
                    {
                        taskClass = "gantt-bar-on-hold";
                    }
                    else
                    {
                        taskClass = "gantt-bar-not-started";
                    }

                    <div class="gantt-row">

                        <div class="gantt-task-column">

                            <a asp-controller="ProjectTask"
                               asp-action="Details"
                               asp-route-id="@task.TaskId"
                               class="gantt-task-link">

                                @task.TaskTitle

                            </a>

                            <span class="gantt-task-meta">

                                <span>@task.TaskCode</span>

                                <span>•</span>

                                <span>
                                    @task.StartDate.ToString("dd MMM")
                                    -
                                    @task.DueDate.ToString("dd MMM")
                                </span>

                            </span>

                            <span class="gantt-assignee">

                                <i class="bi bi-person"></i>

                                <span>
                                    Assigned to:
                                    <strong>
                                        @task.AssignedEmployeeName
                                    </strong>
                                </span>

                            </span>

                            <div class="d-flex flex-wrap gap-2 align-items-center">

                                <span class="gantt-status">
                                    @task.Status
                                </span>

                                @if (task.IsOverdue)
                                {
                                    <span class="gantt-overdue-text">
                                        Overdue by @task.OverdueDays day(s)
                                    </span>
                                }

                            </div>

                        </div>

                        <div class="gantt-timeline">

                            @if (Model.Gantt.TodayPositionPercent.HasValue)
                            {
                                string todayPosition =
                                Model.Gantt.TodayPositionPercent.Value
                                .ToString(
                                "0.##",
                                CultureInfo.InvariantCulture);

                                <div class="gantt-today-line"
                                     style="left: @todayPosition%;">

                                    @if (taskIndex == 0)
                                    {
                                        <span>Today</span>
                                    }

                                </div>
                            }

                            @if (task.IsMilestone)
                            {
                                <div class="gantt-milestone @taskClass"
                                     title="@task.TaskTitle"
                                     style="left: @leftPercent%;">

                                    <span>
                                        @task.DisplayProgressPercent%
                                    </span>

                                </div>
                            }
                            else
                            {
                                <div class="gantt-bar @taskClass"
                                     title="@task.TaskTitle | @task.StartDate.ToString("dd MMM yyyy") - @task.DueDate.ToString("dd MMM yyyy")"
                                     style="left: @leftPercent%;
                                        width: @widthPercent%;">

                                    <div class="gantt-progress"
                                         style="width: @task.DisplayProgressPercent%;">
                                    </div>

                                    <span class="gantt-label">
                                        @task.DisplayProgressPercent%
                                    </span>

                                </div>
                            }

                        </div>

                    </div>
                }
            </div>
            }
    </div>

</div>



<!-- ==========================================
     TASK AND HOURS SUMMARY
=========================================== -->

<div class="row g-3 mb-4">

    <div class="col-lg-6">

        <div class="app-card table-card h-100">

            <div class="card-header">

                <h5 class="card-title">
                    Task Progress
                </h5>

            </div>

            <div class="card-body">

                <div class="mb-2 d-flex justify-content-between">

                    <span>
                        Overall Progress
                    </span>

                    <strong>
                        @Model.OverallProgress.ToString("0.##")%
                    </strong>

                </div>

                <div class="progress mb-4"
                     style="height: 18px;">

                    <div class="progress-bar"
                         role="progressbar"
                         style="width: @Model.OverallProgress.ToString("0.##", CultureInfo.InvariantCulture)%;"
                         aria-valuenow="@Model.OverallProgress"
                         aria-valuemin="0"
                         aria-valuemax="100">

                        @Model.OverallProgress.ToString("0")%

                    </div>

                </div>

                <table class="app-table">

                    <tbody>

                        <tr>
                            <th>Not Started</th>
                            <td>@Model.NotStartedTaskCount</td>
                        </tr>

                        <tr>
                            <th>In Progress</th>
                            <td>@Model.InProgressTaskCount</td>
                        </tr>

                        <tr>
                            <th>Completed</th>
                            <td>@Model.CompletedTaskCount</td>
                        </tr>

                        <tr>
                            <th>Overdue</th>
                            <td>@Model.OverdueTaskCount</td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="col-lg-6">

        <div class="app-card table-card h-100">

            <div class="card-header">

                <h5 class="card-title">
                    Hours Summary
                </h5>

            </div>

            <div class="card-body">

                <table class="app-table">

                    <tbody>

                        <tr>
                            <th>Estimated Hours</th>

                            <td>
                                @Model.EstimatedHours.ToString("N2")
                            </td>
                        </tr>

                        <tr>
                            <th>Actual Hours</th>

                            <td>
                                @Model.ActualHours.ToString("N2")
                            </td>
                        </tr>

                        <tr>
                            <th>Variance</th>

                            <td>
                                @{
                                    decimal variance =
                                    Model.EstimatedHours -
                                    Model.ActualHours;
                                }

                                @variance.ToString("N2")
                            </td>
                        </tr>

                        <tr>
                            <th>Current Milestone</th>

                            <td>
                                @Model.CurrentFlowStage
                            </td>
                        </tr>

                        <tr>
                            <th>Milestone Status</th>

                            <td>
                                @Model.CurrentFlowStatus
                            </td>
                        </tr>

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>

<!-- ==========================================
     RISK AND MEETING SUMMARY
=========================================== -->

<div class="row g-3">

    <div class="col-lg-6">

        <div class="app-card table-card h-100">

            <div class="card-header">

                <h5 class="card-title">
                    Risk Summary
                </h5>

            </div>

            <div class="card-body">

                <table class="app-table">

                    <tbody>

                        <tr>
                            <th>Open Risks</th>
                            <td>@Model.OpenRiskCount</td>
                        </tr>

                        <tr>
                            <th>Critical Risks</th>
                            <td>@Model.CriticalRiskCount</td>
                        </tr>

                    </tbody>

                </table>

                <div class="mt-3">

                    <a asp-controller="Risk"
                       asp-action="Index"
                       asp-route-projectId="@Model.Project.Id"
                       class="btn-app btn-secondary-app">
                        <i class="bi bi-exclamation-triangle"></i>
                        Risk Register
                    </a>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-6">

        <div class="app-card table-card h-100">

            <div class="card-header">

                <h5 class="card-title">
                    Meeting Summary
                </h5>

            </div>

            <div class="card-body">

                <table class="app-table">

                    <tbody>

                        <tr>
                            <th>Upcoming Meetings</th>

                            <td>
                                @Model.UpcomingMeetingCount
                            </td>
                        </tr>

                    </tbody>

                </table>

                <div class="mt-3">

                    <a asp-controller="MOM"
                       asp-action="Index"
                       asp-route-projectId="@Model.Project.Id"
                       class="btn-app btn-secondary-app">
                        <i class="bi bi-journal-text"></i>
                        Meetings / MOM
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>
