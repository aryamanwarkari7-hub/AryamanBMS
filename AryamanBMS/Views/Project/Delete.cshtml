@model AryamanBMS.Models.ProjectModel

@{
    ViewData["Title"] = "Deactivate Project";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Deactivate Project</h1>
        <p class="module-subtitle">Confirm project deactivation</p>
    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Project Information</h5>
    </div>

    <div class="card-body">

        <div class="form-grid-2">

            <div class="form-group">
                <label class="form-label">Project Code</label>
                <input value="@Model.ProjectCode"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Project Name</label>
                <input value="@Model.ProjectName"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Client Name</label>
                <input value="@(Model.ClientName ?? "-")"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Project Manager</label>
                <input value="@(Model.ProjectManager?.FullName ?? "-")"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Project Type</label>
                <input value="@Model.ProjectType"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Budget</label>
                <input value="₹@Model.Budget.ToString("N2")"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Status</label>
                <input value="@Model.Status"
                       class="app-input"
                       readonly />
            </div>

            <div class="form-group">
                <label class="form-label">Priority</label>
                <input value="@Model.Priority"
                       class="app-input"
                       readonly />
            </div>

        </div>

        <div class="app-alert app-alert-danger mt-4">
            This action will permanently delete this project. Continue only if the project has no dependent members, tasks, budgets, risks or meetings.
        </div>

        <div class="mt-4">

            <form asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn-app btn-danger-app">
                    Deactivate Project
                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">
                    Cancel
                </a>

            </form>

        </div>

    </div>

</div>


                                                  