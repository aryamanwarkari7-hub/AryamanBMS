@model AryamanBMS.Models.ProjectModel

@{
    ViewData["Title"] = "Add Project";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Add Project</h1>
        <p class="module-subtitle">Create a new project</p>
    </div>

</div>

<form asp-action="Create"
      method="post">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="validation-message mb-3"></div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Basic Information</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Project Code</label>
                    <input asp-for="ProjectCode"
                           class="app-input"
                           placeholder="Example: PRJ001" />
                    <span asp-validation-for="ProjectCode"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Project Name</label>
                    <input asp-for="ProjectName"
                           class="app-input" />
                    <span asp-validation-for="ProjectName"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Project Type</label>
                    <select asp-for="ProjectType"
                            class="app-select">
                        <option value="">Select Project Type</option>
                        <option value="Software">Software</option>
                        <option value="Infrastructure">Infrastructure</option>
                        <option value="Consulting">Consulting</option>
                        <option value="Internal">Internal</option>
                        <option value="Other">Other</option>
                    </select>
                    <span asp-validation-for="ProjectType"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Client Name</label>
                    <input asp-for="ClientName"
                           class="app-input" />
                    <span asp-validation-for="ClientName"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Project Manager</label>
                    <select asp-for="ProjectManagerId"
                            class="app-select">
                        <option value="">Select Project Manager</option>

                        @foreach (var employee in ViewBag.ProjectManagers)
                        {
                            <option value="@employee.Id">@employee.FullName</option>
                        }
                    </select>
                    <span asp-validation-for="ProjectManagerId"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Priority</label>
                    <select asp-for="Priority"
                            class="app-select">
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                        <option value="Critical">Critical</option>
                    </select>
                    <span asp-validation-for="Priority"
                          class="validation-message"></span>
                </div>

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Schedule and Budget</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                <div class="form-group">
                    <label class="form-label">Start Date</label>
                    <input asp-for="StartDate"
                           type="date"
                           class="app-input" />
                    <span asp-validation-for="StartDate"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">End Date</label>
                    <input asp-for="EndDate"
                           type="date"
                           class="app-input" />
                    <span asp-validation-for="EndDate"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Budget</label>
                    <input asp-for="Budget"
                           type="number"
                           step="0.01"
                           min="0"
                           class="app-input" />
                    <span asp-validation-for="Budget"
                          class="validation-message"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">Status</label>
                    <select asp-for="Status"
                            class="app-select">
                        <option value="Planning">Planning</option>
                        <option value="In Progress">In Progress</option>
                        <option value="On Hold">On Hold</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                    <span asp-validation-for="Status"
                          class="validation-message"></span>
                </div>

            </div>

        </div>

    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Project Description</h5>
        </div>

        <div class="card-body">

            <div class="form-group mb-3">
                <label class="form-label">Business Objective</label>
                <textarea asp-for="BusinessObjective"
                          rows="4"
                          class="app-textarea"></textarea>
                <span asp-validation-for="BusinessObjective"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label class="form-label">Scope</label>
                <textarea asp-for="Scope"
                          rows="5"
                          class="app-textarea"></textarea>
                <span asp-validation-for="Scope"
                      class="validation-message"></span>
            </div>

        </div>

    </div>

    <div class="app-card">
        <div class="card-body">
            <button type="submit"
                    class="btn-app btn-primary-app">
                Save Project
            </button>

            <a asp-action="Index"
               class="btn-app btn-secondary-app">
                Cancel
            </a>
        </div>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
