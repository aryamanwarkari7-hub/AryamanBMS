@model IEnumerable<AryamanBMS.Models.ProjectModel>

@{
    ViewData["Title"] = "Projects";

    string searchText = ViewBag.SearchText as string ?? "";
    string status = ViewBag.Status as string ?? "";
    string priority = ViewBag.Priority as string ?? "";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, currentPage + 2);
}

<div class="module-header">

    <div>
        <h1 class="module-title">Projects</h1>
        <p class="module-subtitle">Manage project records</p>
    </div>

    <a asp-action="Create"
       class="btn-app btn-primary-app">
        <i class="bi bi-plus-lg"></i>
        Add Project
    </a>

</div>



<div class="app-card table-card">

    <div class="card-header">
        <h5 class="card-title">Project List</h5>
    </div>

    <div class="app-card mb-3">

        <div class="card-body">

            <form asp-action="Index"
                  method="get">

                <div class="filter-form-row">

                    <input type="text"
                           name="searchText"
                           value="@searchText"
                           class="app-input flex-grow-1"
                           placeholder="Search by code, project name or client" />

                    <div class="d-flex flex-row flex-grow gap-2">
                    <select name="status" class="app-select">

                        <option value="">All Status</option>

                        @foreach (var option in new[] { "Planning", "In Progress", "On Hold", "Completed", "Cancelled" })
                        {
                            if (status == option)
                            {
                                <option value="@option" selected>@option</option>
                            }
                            else
                            {
                                <option value="@option">@option</option>
                            }
                        }

                    </select>

                    <select name="priority"
                            class="app-select">

                        <option value="">All Priority</option>

                        @foreach (var option in new[] { "Low", "Medium", "High", "Critical" })
                        {
                            if (priority == option)
                            {
                                <option value="@option" selected>@option</option>
                            }
                            else
                            {
                                <option value="@option">@option</option>
                            }
                        }

                    </select>
                    </div>

                    <div class="filter-form-actions">
                        <button type="submit"
                                class="btn-app btn-primary-app">
                            <i class="bi bi-search"></i>
                            Search
                        </button>

                        <a asp-action="Index"
                           class="btn-app btn-secondary-app">
                            Reset
                        </a>
                    </div>

                </div>

            </form>

        </div>

    </div>

    <div class="card-body">

        <div class="table-responsive">

            @if (!Model.Any())
            {
                <div class="empty-state">
                    No project records found.
                </div>
            }
            else
            {
                <table class="app-table">

                    <thead>
                        <tr>
                            <th>Code</th>
                            <th>Project</th>
                            <th>Client</th>
                            <th>Manager</th>
                            <th>Schedule</th>
                            <th>Budget</th>
                            <th>Status</th>
                            <th>Priority</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var project in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@project.ProjectCode</strong>
                                </td>

                                <td>
                                    <div>
                                        <strong>@project.ProjectName</strong>
                                        <br />
                                        <small>@project.ProjectType</small>
                                    </div>
                                </td>

                                <td>@(project.ClientName ?? "-")</td>

                                <td>
                                    @(project.ProjectManager?.FullName ?? "-")
                                </td>

                                <td>
                                    <div>
                                        <small>
                                            @(project.StartDate?.ToString("dd-MMM-yyyy") ?? "-")
                                            to
                                            @(project.EndDate?.ToString("dd-MMM-yyyy") ?? "-")
                                        </small>
                                    </div>
                                </td>

                                <td>
                                    ₹@project.Budget.ToString("N2")
                                </td>

                                <td>
                                    @if (project.Status == "Completed")
                                    {
                                        <span class="badge-success">Completed</span>
                                    }
                                    else if (project.Status == "Cancelled" || project.Status == "On Hold")
                                    {
                                        <span class="badge-danger">@project.Status</span>
                                    }
                                    else
                                    {
                                        <span class="badge-warning">@project.Status</span>
                                    }
                                </td>

                                <td>
                                    @if (project.Priority == "Critical" || project.Priority == "High")
                                    {
                                        <span class="badge-danger">@project.Priority</span>
                                    }
                                    else if (project.Priority == "Low")
                                    {
                                        <span class="badge-success">Low</span>
                                    }
                                    else
                                    {
                                        <span class="badge-warning">Medium</span>
                                    }
                                </td>

                                <td>
                                    <div class="table-actions">

                                        <a asp-action="Dashboard"
                                           asp-route-id="@project.Id"
                                           class="btn-app btn-primary-app btn-icon"
                                           title="Open Workspace">
                                            <i class="bi bi-kanban"></i>
                                        </a>

                                        <a asp-action="Details"
                                           asp-route-id="@project.Id"
                                           class="btn-app btn-secondary-app btn-icon"
                                           title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@project.Id"
                                           class="btn-app btn-secondary-app btn-icon"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@project.Id"
                                           class="btn-app btn-danger-app btn-icon"
                                           title="Deactivate">
                                            <i class="bi bi-trash"></i>
                                        </a>

                                    </div>
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            }

        </div>

    </div>

    @if (totalPages > 1)
    {
        <div class="app-pagination">

            <a asp-action="Index"
               asp-route-page="@(currentPage - 1)"
               asp-route-searchText="@searchText"
               asp-route-status="@status"
               asp-route-priority="@priority"
               class="pagination-btn @(currentPage == 1 ? "disabled" : "")">

                <i class="bi bi-chevron-left"></i>
                Previous
            </a>

            @if (startPage > 1)
            {
                <a asp-action="Index"
                   asp-route-page="1"
                   asp-route-searchText="@searchText"
                   asp-route-status="@status"
                   asp-route-priority="@priority"
                   class="pagination-number">
                    1
                </a>

                @if (startPage > 2)
                {
                    <span class="pagination-dots">...</span>
                }
            }

            @for (int pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                <a asp-action="Index"
                   asp-route-page="@pageNumber"
                   asp-route-searchText="@searchText"
                   asp-route-status="@status"
                   asp-route-priority="@priority"
                   class="pagination-number @(pageNumber == currentPage ? "active" : "")">
                    @pageNumber
                </a>
            }

            @if (endPage < totalPages)
            {
                @if (endPage < totalPages - 1)
                {
                    <span class="pagination-dots">...</span>
                }

                <a asp-action="Index"
                   asp-route-page="@totalPages"
                   asp-route-searchText="@searchText"
                   asp-route-status="@status"
                   asp-route-priority="@priority"
                   class="pagination-number">
                    @totalPages
                </a>
            }

            <a asp-action="Index"
               asp-route-page="@(currentPage + 1)"
               asp-route-searchText="@searchText"
               asp-route-status="@status"
               asp-route-priority="@priority"
               class="pagination-btn @(currentPage == totalPages ? "disabled" : "")">

                Next
                <i class="bi bi-chevron-right"></i>
            </a>

        </div>
    }

</div>
