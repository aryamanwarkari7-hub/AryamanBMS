<div>

<div class="content-container">


    <div class="app-card">

        <div class="card-header">

            <h5 class="card-title">
                Employee Statistics
            </h5>

            <span class="card-subtitle">
                Current FY
            </span>

        </div>

        <div class="card-body">

            This is a sample card.

        </div>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Buttons</h5>
    </div>

    <div class="card-body">

        <button class="btn-app btn-primary-app">
            Save
        </button>

        <button class="btn-app btn-secondary-app">
            Cancel
        </button>

        <button class="btn-app btn-success-app">
            Approve
        </button>

        <button class="btn-app btn-outline-app">
            <i class="bi bi-eye"></i>
        </button>

        <button class="btn-app btn-secondary-app btn-icon">
            <i class="bi bi-pencil"></i>
        </button>

        <button class="btn-app btn-danger-app">
            <i class="bi bi-trash"></i>
        </button>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Forms</h5>
    </div>

    <div class="card-body">

        <div class="form-grid-3">

            <div class="form-group">

                <label class="form-label">
                    First Name
                </label>

                <input type="text"
                       class="app-input"
                       placeholder="Enter first name" />

            </div>

            <div class="form-group">

                <label class="form-label">
                    Department
                </label>

                <select class="app-select">

                    <option>Select Department</option>
                    <option>HR</option>
                    <option>Finance</option>

                </select>

            </div>

            <div class="form-group">

                <label class="form-label">
                    Joining Date
                </label>

                <input type="date"
                       class="app-input" />

            </div>

        </div>

        <br />

        <div class="form-group">

            <label class="form-label">
                Remarks
            </label>

            <textarea class="app-textarea"
                      placeholder="Enter remarks"></textarea>

        </div>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Employee List
        </h5>

    </div>

    <div class="card-body">

        <table class="app-table">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Department</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <tr>
                    <td>1</td>
                    <td>John Doe</td>
                    <td>HR</td>
                    <td>
                        <span class="badge-success">
                            Active
                        </span>
                    </td>
                    <td>
                        <div class="table-actions">

                            <button class="btn-app btn-secondary-app btn-icon">
                                <i class="bi bi-pencil"></i>
                            </button>

                            <button class="btn-app btn-danger-app btn-icon">
                                <i class="bi bi-trash"></i>
                            </button>

                        </div>
                    </td>
                </tr>

            </tbody>

        </table>

    </div>

</div>

