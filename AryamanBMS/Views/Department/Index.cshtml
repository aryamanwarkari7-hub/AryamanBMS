@model AryamanBMS.ViewModels.PagedListViewModel<AryamanBMS.Models.DepartmentModel >

@{
    ViewData["Title"] = "Departments";
}

<div class="module-header">

    <div>
        <h1 class="module-title">
            Department Master
        </h1>

        <p class="module-subtitle">
            Manage department records
        </p>
    </div>

    <a asp-action="Create"
       class="btn-app btn-primary-app">

        <i class="bi bi-plus-lg"></i>
        Add Department

    </a>

</div>

@if (TempData["Error"] != null)
{
    <div class="app-alert app-alert-danger mb-3">
        <i class="bi bi-exclamation-circle"></i>
        @TempData["Error"]
    </div>
}

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Department List
        </h5>

    </div>

    <div class="card-body border-bottom">

        <form asp-action="Index"
              method="get">

            <div class="d-flex flex-wrap gap-2">

                <input type="text"
                       name="searchText"
                       value="@ViewBag.SearchText"
                       class="app-input flex-grow-1"
                       placeholder="Search department name or code"
                       autocomplete="off" />

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Search

                </button>

                <a asp-action="Index"
                   class="btn-app btn-secondary-app">

                    <i class="bi bi-arrow-counterclockwise"></i>
                    Reset

                </a>

            </div>

        </form>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-building"></i>

                <p class="mb-0">
                    No department records found.
                </p>

            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Department Name</th>
                            <th>Department Code</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var department in Model.Items)
                        {
                            <tr>

                                <td>
                                    @department.Id
                                </td>

                                <td>
                                    <strong>
                                        @department.DepartmentName
                                    </strong>
                                </td>

                                <td>
                                    @department.DisplayCode
                                </td>

                                <td>

                                    @if (department.IsActive)
                                    {
                                        <span class="badge-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-danger">
                                            Inactive
                                        </span>
                                    }

                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Edit"
                                           asp-route-id="@department.Id"
                                           class="btn-app btn-secondary-app btn-icon"
                                           title="Edit department"
                                           aria-label="Edit department">

                                            <i class="bi bi-pencil"></i>

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@department.Id"
                                           class="btn-app btn-danger-app btn-icon"
                                           title="Delete department"
                                           aria-label="Delete department">

                                            <i class="bi bi-trash"></i>

                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>