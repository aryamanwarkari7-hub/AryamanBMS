@model AryamanBMS.Models.ProjectFlowModel

@{
    ViewData["Title"] = "Edit Milestone";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Edit Milestone</h1>
        <p class="module-subtitle">
            Update project milestone information
        </p>
    </div>

    <a asp-action="Details"
       asp-route-id="@Model.Id"
       class="btn-app btn-secondary-app">
        Back
    </a>

</div>

<form asp-action="Edit"
      method="post">

    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />
    

    <div asp-validation-summary="ModelOnly"
         class="validation-message">
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Milestone Information</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                <input type="hidden" asp-for="ProjectId" />

                <div class="form-group">
                    <label>Project</label>

                    <input type="text"
                           class="app-input"
                           value="@Model.Project?.ProjectCode - @Model.Project?.ProjectName"
                           readonly />
                </div>

                <div class="form-group">
                    <label asp-for="StageOrder">
                        Sequence
                    </label>

                    <input asp-for="StageOrder"
                           type="number"
                           min="1"
                           class="app-input" />

                    <span asp-validation-for="StageOrder"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="StageName">
                        Milestone Name
                    </label>

                    <input asp-for="StageName"
                           class="app-input" />

                    <span asp-validation-for="StageName"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="StageStatus">
                        Milestone Status
                    </label>

                    <select asp-for="StageStatus"
                            class="app-select">

                        <option value="Pending">Pending</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                        <option value="On Hold">On Hold</option>

                    </select>

                    <span asp-validation-for="StageStatus"
                          class="validation-message">
                    </span>

                    <small class="text-muted">
                        Actual dates are adjusted automatically based on milestone status.
                    </small>
                </div>

                <div class="form-group">
                    <label asp-for="PlannedStartDate">
                        Planned Start Date
                    </label>
                    <span asp-validation-for="PlannedStartDate"
                          class="validation-message">
                    </span>

                    <input asp-for="PlannedStartDate"
                           type="date"
                           class="app-input" />
                </div>

                <div class="form-group">
                    <label asp-for="PlannedEndDate">
                        Planned End Date
                    </label>

                    <input asp-for="PlannedEndDate"
                           type="date"
                           class="app-input" />

                    <span asp-validation-for="PlannedEndDate"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="ActualStartDate">
                        Actual Start Date / Started On
                    </label>

                    <input asp-for="ActualStartDate"
                           type="date"
                           class="app-input" />
                </div>

                <div class="form-group">
                    <label asp-for="ActualEndDate">
                        Actual End Date / Completed On
                    </label>

                    <input asp-for="ActualEndDate"
                           type="date"
                           class="app-input" />

                    <span asp-validation-for="ActualEndDate"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="IsActive">
                        Active Status
                    </label>

                    <select asp-for="IsActive"
                            class="app-select">

                        <option value="true">Active</option>
                        <option value="false">Inactive</option>

                    </select>

                </div>

            </div>

            <div class="form-group mt-3">

                <label asp-for="Remarks">
                    Remarks
                </label>

                <textarea asp-for="Remarks"
                          rows="4"
                          class="app-textarea">
                </textarea>

                <span asp-validation-for="Remarks"
                      class="validation-message">
                </span>

            </div>

        </div>
    </div>

    <div class="app-card">
        <div class="card-body">

            <button type="submit"
                    class="btn-app btn-primary-app ">

                @* <i class="bi bi-check-lg"></i> *@
                Update

            </button>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn-app btn-secondary-app ">
                Cancel
            </a>

        </div>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
