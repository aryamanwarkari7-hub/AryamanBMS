@model IEnumerable<AryamanBMS.Models.ProjectFlowModel>

@{
    ViewData["Title"] = "Milestones";
}

<div class="module-header">
    <div>
        <h1 class="module-title">Milestones</h1>
        <p class="module-subtitle">
            Manage project lifecycle stages
        </p>
    </div>

    <a asp-action="Create"
       asp-route-projectId="@ViewBag.ProjectId"
       class="btn-app btn-primary-app">

        <i class="bi bi-plus-lg"></i>
        Add Stage

    </a>
</div>



<div class="app-card">
    <div class="card-body">

        <form asp-action="Index"
              method="get">

            <div class="form-grid-2">

                <div class="form-group">
                    <label>Project</label>

                    <select name="projectId"
                            class="app-select">

                        <option value="">All Projects</option>

                        @foreach (var project in ViewBag.Projects)
                        {
                            <option value="@project.Id"
                                    selected="@(ViewBag.ProjectId == project.Id)">
                                @project.ProjectCode - @project.ProjectName
                            </option>
                        }

                    </select>
                </div>

                <div class="form-group d-flex flex-row align-items-end gap-2">

                    <button type="submit"
                            class="btn-app btn-primary-app">
                        Filter
                    </button>

                    <a asp-action="Index"
                       class="btn-app btn-secondary-app">
                        Reset
                    </a>

                </div>

            </div>

        </form>

    </div>
</div>

<div class="app-card table-card">

    <div class="card-header">
        <h5 class="card-title">Milestones</h5>
    </div>

    <div class="card-body">

        <table class="app-table">

            <thead>
                <tr>
                    <th>Project</th>
                    <th>Order</th>
                    <th>Stage</th>
                    <th>Status</th>
                    <th>Planned Start</th>
                    <th>Planned End</th>
                    <th>Actual Start</th>
                    <th>Actual End</th>
                    <th>Active</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Any())
                {
                    foreach (var flow in Model)
                    {
                        <tr>

                            <td>
                                @flow.Project?.ProjectCode
                            </td>

                            <td>
                                @flow.StageOrder
                            </td>

                            <td>
                                @flow.StageName
                            </td>

                            <td>
                                @flow.StageStatus
                            </td>

                            <td>
                                @(flow.PlannedStartDate?.ToString("dd-MM-yyyy") ?? "-")
                            </td>

                            <td>
                                @(flow.PlannedEndDate?.ToString("dd-MM-yyyy") ?? "-")
                            </td>

                            <td>
                                @(flow.ActualStartDate?.ToString("dd-MM-yyyy") ?? "-")
                            </td>

                            <td>
                                @(flow.ActualEndDate?.ToString("dd-MM-yyyy") ?? "-")
                            </td>

                            <td>
                                @if (flow.IsActive)
                                {
                                    <span class="status-badge status-active">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">
                                        Inactive
                                    </span>
                                }
                            </td>

                            <td>
                                <div class="action-buttons d-flex flex-row gap-1">

                                    <a asp-action="Details"
                                       asp-route-id="@flow.Id"
                                       class="btn-app btn-icon btn-primary-app btn-view"
                                       title="Details">

                                        <i class="bi bi-eye"></i>

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@flow.Id"
                                       class="btn-app btn-icon btn-secondary-app btn-edit"
                                       title="Edit">

                                        <i class="bi bi-pencil"></i>

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@flow.Id"
                                       class="btn-app btn-icon btn-danger-app btn-delete btn-app"
                                       title="Deactivate">

                                        <i class="bi bi-trash"></i>

                                    </a>

                                </div>
                            </td>

                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10"
                            class="text-center text-muted">
                            No project stages found.
                        </td>
                    </tr>
                }

            </tbody>

        </table>

    </div>
</div>