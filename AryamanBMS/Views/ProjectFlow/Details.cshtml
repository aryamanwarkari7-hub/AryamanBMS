@model AryamanBMS.Models.ProjectFlowModel

@{
    ViewData["Title"] = "Project Stage Details";
}

<div class="module-header">

    <div>
        <h1 class="module-title">Milestone Details</h1>
        <p class="module-subtitle">
            View lifecycle stage information
        </p>
    </div>

    <div class="d-flex gap-2">

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn-app btn-primary-app btn-icon">

            <i class="bi bi-pencil"></i>
            Edit

        </a>

        <a asp-action="Index"
           asp-route-projectId="@Model.ProjectId"
           class="btn-app btn-secondary-app btn-icon">
            Back
        </a>

    </div>

</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Stage Information</h5>
    </div>

    <div class="card-body">

        <table class="app-table">

            <tbody>

                <tr>
                    <th>Project</th>
                    <td>
                        @Model.Project?.ProjectCode -
                        @Model.Project?.ProjectName
                    </td>
                </tr>

                <tr>
                    <th>Stage Order</th>
                    <td>@Model.StageOrder</td>
                </tr>

                <tr>
                    <th>Stage Name</th>
                    <td>@Model.StageName</td>
                </tr>

                <tr>
                    <th>Stage Status</th>
                    <td>@Model.StageStatus</td>
                </tr>

                <tr>
                    <th>Planned Start</th>
                    <td>
                        @(Model.PlannedStartDate?.ToString("dd-MM-yyyy") ?? "-")
                    </td>
                </tr>

                <tr>
                    <th>Planned End</th>
                    <td>
                        @(Model.PlannedEndDate?.ToString("dd-MM-yyyy") ?? "-")
                    </td>
                </tr>

                <tr>
                    <th>Actual Start</th>
                    <td>
                        @(Model.ActualStartDate?.ToString("dd-MM-yyyy") ?? "-")
                    </td>
                </tr>

                <tr>
                    <th>Actual End</th>
                    <td>
                        @(Model.ActualEndDate?.ToString("dd-MM-yyyy") ?? "-")
                    </td>
                </tr>

                <tr>
                    <th>Status</th>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="status-badge status-active">
                                Active
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">
                                Inactive
                            </span>
                        }
                    </td>
                </tr>

                <tr>
                    <th>Created On</th>
                    <td>
                        @Model.CreatedOn.ToString("dd-MM-yyyy hh:mm tt")
                    </td>
                </tr>

                <tr>
                    <th>Updated On</th>
                    <td>
                        @(Model.UpdatedOn?.ToString("dd-MM-yyyy hh:mm tt") ?? "-")
                    </td>
                </tr>

            </tbody>

        </table>

    </div>
</div>

<div class="app-card">

    <div class="card-header">
        <h5 class="card-title">Remarks</h5>
    </div>

    <div class="card-body">

        @if (!string.IsNullOrWhiteSpace(Model.Remarks))
        {
            <p class="mb-0">@Model.Remarks</p>
        }
        else
        {
            <p class="text-muted mb-0">
                No remarks provided.
            </p>
        }

    </div>

</div>