@model AryamanBMS.Models.ProjectFlowModel

@{
    ViewData["Title"] = "Add Milestone";
}

<div class="module-header">
    <div>
        <h1 class="module-title">Add Milestone</h1>
        <p class="module-subtitle">
            Add a new project milestone
        </p>
    </div>

    <a asp-action="Index"
       asp-route-projectId="@Model.ProjectId"
       class="btn-app btn-secondary-app">
        Back
    </a>
</div>

<form asp-action="Create"
      method="post">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly"
         class="validation-message">
    </div>

    <div class="app-card">

        <div class="card-header">
            <h5 class="card-title">Milestone Information</h5>
        </div>

        <div class="card-body">

            <div class="form-grid-2">

                <div class="form-group">
                    <label asp-for="ProjectId">Project</label>

                    <select asp-for="ProjectId"
                            id="milestoneProjectSelect"
                            class="app-select">

                        <option value="">Select Project</option>

                        @foreach (var project in ViewBag.Projects)
                        {
                            <option value="@project.Id">
                                @project.ProjectCode - @project.ProjectName
                            </option>
                        }

                    </select>

                    <span asp-validation-for="ProjectId"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="StageOrder">
                        Sequence
                    </label>

                    <input asp-for="StageOrder"
                           id="milestoneSequenceInput"
                           type="number"
                           min="1"
                           class="app-input" />

                    <span asp-validation-for="StageOrder"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="StageName">
                        Milestone Name
                    </label>

                    <input asp-for="StageName"
                           class="app-input"
                           placeholder="Example: Requirement Gathering" />

                    <span asp-validation-for="StageName"
                          class="validation-message">
                    </span>
                </div>

                <div class="form-group">
                    <label asp-for="PlannedStartDate">
                        Planned Start Date
                    </label>

                    <span asp-validation-for="PlannedStartDate"
                          class="validation-message">
                    </span>

                    <input asp-for="PlannedStartDate"
                           type="date"
                           class="app-input" />
                </div>

                <div class="form-group">
                    <label asp-for="PlannedEndDate">
                        Planned End Date
                    </label>

                    <input asp-for="PlannedEndDate"
                           type="date"
                           class="app-input" />

                    <span asp-validation-for="PlannedEndDate"
                          class="validation-message">
                    </span>
                </div>
                           
                                
            </div>

            <div class="form-group mt-3">

                <label asp-for="Remarks">
                    Remarks
                </label>

                <textarea asp-for="Remarks"
                          rows="4"
                          class="app-textarea">
                </textarea>

                <span asp-validation-for="Remarks"
                      class="validation-message">
                </span>

            </div>

        </div>
    </div>

    <div class="app-card">
        <div class="card-body">

            <button type="submit"
                    class="btn-app btn-primary-app">

                <i class="bi bi-check-lg"></i>
                Create Milestone

            </button>

            <a asp-action="Index"
               asp-route-projectId="@Model.ProjectId"
               class="btn-app btn-secondary-app">
                Cancel
            </a>

        </div>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/project-flow.js" asp-append-version="true"></script>
}