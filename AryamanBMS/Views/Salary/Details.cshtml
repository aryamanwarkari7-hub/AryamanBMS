@model AryamanBMS.Models.SalaryRecordModel

@{
    ViewData["Title"] = "Salary Details";
}

<div class="module-header">

    <div>

        <h1 class="module-title">
            Salary Details
        </h1>

        <p class="module-subtitle">
            Excel-imported payroll breakdown
        </p>

    </div>

    <a asp-action="Index"
       class="btn-app btn-secondary-app">

        Back

    </a>

</div>

<div class="app-card">

    <div class="card-header">

        <h5 class="card-title">

            @Model.Employee?.FullName
            (@Model.Employee?.EmployeeCode)

        </h5>

    </div>

    <div class="card-body">

        <div class="form-grid-2">

            <div>
                <strong>Month</strong><br />
                @Model.Month/@Model.Year
            </div>

            <div>
                <strong>Status</strong><br />

                @if (Model.PaymentStatus == "Paid")
                {
                    <span class="badge-success">
                        Paid
                    </span>
                }
                else
                {
                    <span class="badge-warning">
                        Pending
                    </span>
                }
            </div>

            <div>
                <strong>Pay Days</strong><br />
                @Model.PayDays.ToString("N2")
            </div>

            <div>
                <strong>Source File</strong><br />
                @(Model.SourceFileName ?? "-")
            </div>

        </div>

        <hr />

        <h6>Earnings</h6>

        <table class="table">

            <tr>
                <td>Actual Salary</td>
                <td>₹ @Model.ActualSalary.ToString("N2")</td>
            </tr>

            <tr>
                <td>Gross Salary</td>
                <td>₹ @Model.GrossSalary.ToString("N2")</td>
            </tr>

            <tr>
                <td>Basic Salary</td>
                <td>₹ @Model.BasicSalary.ToString("N2")</td>
            </tr>

            <tr>
                <td>HRA</td>
                <td>₹ @Model.HRA.ToString("N2")</td>
            </tr>

            <tr>
                <td>Conveyance</td>
                <td>₹ @Model.Conveyance.ToString("N2")</td>
            </tr>

            <tr>
                <td>Medical Allowance</td>
                <td>₹ @Model.MedicalAllowance.ToString("N2")</td>
            </tr>

            <tr>
                <td>Education Allowance</td>
                <td>₹ @Model.EducationAllowance.ToString("N2")</td>
            </tr>

            <tr>
                <td>Special Allowance</td>
                <td>₹ @Model.SpecialAllowance.ToString("N2")</td>
            </tr>

            <tr>
                <th>Total Earnings</th>
                <th>₹ @Model.TotalEarnings.ToString("N2")</th>
            </tr>

            <tr>
                <td>Gross - Conveyance</td>
                <td>₹ @Model.GrossMinusConveyance.ToString("N2")</td>
            </tr>

        </table>

        <hr />

        <h6>Deductions</h6>

        <table class="table">

            <tr>
                <td>PF Employee</td>
                <td>₹ @Model.PfDeduction.ToString("N2")</td>
            </tr>

            <tr>
                <td>ESIC Employee</td>
                <td>₹ @Model.EsicDeduction.ToString("N2")</td>
            </tr>

            <tr>
                <td>Professional Tax</td>
                <td>₹ @Model.ProfessionalTax.ToString("N2")</td>
            </tr>

            <tr>
                <td>Advance</td>
                <td>₹ @Model.Advance.ToString("N2")</td>
            </tr>

            <tr>
                <th>Total Deductions</th>
                <th>₹ @Model.TotalDeductions.ToString("N2")</th>
            </tr>

            <tr>
                <th>Net Salary</th>
                <th>₹ @Model.NetSalary.ToString("N2")</th>
            </tr>

        </table>

        <hr />

        <h6>Employer Contribution</h6>

        <table class="table">

            <tr>
                <td>Employer PF</td>
                <td>₹ @Model.EmployerPf.ToString("N2")</td>
            </tr>

            <tr>
                <td>Employer ESIC</td>
                <td>₹ @Model.EmployerEsic.ToString("N2")</td>
            </tr>

            <tr>
                <th>CTC</th>
                <th>₹ @Model.CTC.ToString("N2")</th>
            </tr>

        </table>

        @if (!string.IsNullOrWhiteSpace(Model.Remark))
        {
            <hr />

            <strong>Remark:</strong>
            @Model.Remark
        }

        @if (Model.PaidOn != null)
        {
            <hr />

            <strong>Paid On:</strong>
            @Model.PaidOn.Value.ToString("dd-MMM-yyyy HH:mm")
        }

    </div>

</div>