@model PagedListViewModel<SalaryRecordModel>

@{
    ViewData["Title"] = "Salary Register";

    int selectedMonth = (int)ViewBag.Month;
    int selectedYear = (int)ViewBag.Year;
}

<div class="module-header">

    <div>

        <h1 class="module-title">
            Salary Register
        </h1>

        <p class="module-subtitle">
            Monthly payroll management
        </p>

    </div>

</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">

        @TempData["Success"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show"
         role="alert">

        @Html.Raw(TempData["Error"])

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert">
        </button>

    </div>
}

<div class="app-card mb-3">

    <div class="card-header">

        <h5 class="card-title">
            Salary Period
        </h5>

    </div>

    <div class="card-body">

        <div class="d-flex justify-content-between
            align-items-end flex-wrap gap-3">

            <form asp-action="Index"
                  method="get"
                  class="d-flex gap-2 align-items-end flex-wrap">

                <div>

                    <label class="form-label"
                           for="month">
                        Month
                    </label>

                    <select id="month"
                            name="month"
                            class="app-select">

                        @for (int month = 1;
                              month <= 12;
                              month++)
                        {
                            string monthName =
                                new DateTime(2000, month, 1)
                                    .ToString("MMMM");

                            if (month == selectedMonth)
                            {
                                <option value="@month"
                                        selected>
                                    @monthName
                                </option>
                            }
                            else
                            {
                                <option value="@month">
                                    @monthName
                                </option>
                            }
                        }

                    </select>

                </div>

                <div>

                    <label class="form-label"
                           for="year">
                        Year
                    </label>

                    <select id="year"
                            name="year"
                            class="app-select">

                        @for (int year = DateTime.Today.Year - 2;
                              year <= DateTime.Today.Year + 2;
                              year++)
                        {
                            if (year == selectedYear)
                            {
                                <option value="@year"
                                        selected>
                                    @year
                                </option>
                            }
                            else
                            {
                                <option value="@year">
                                    @year
                                </option>
                            }
                        }

                    </select>

                </div>

                <button type="submit"
                        class="btn-app btn-primary-app">

                    <i class="bi bi-search"></i>
                    Load

                </button>

            </form>

            <div class="d-flex gap-2 flex-wrap">

                <a asp-action="AttendanceSummary"
                   asp-route-month="@selectedMonth"
                   asp-route-year="@selectedYear"
                   class="btn-app btn-outline-app">

                    <i class="bi bi-calendar-check"></i>
                    Attendance Summary

                </a>

                <a asp-action="ExportExcel"
                   asp-route-month="@selectedMonth"
                   asp-route-year="@selectedYear"
                   class="btn-app btn-success-app">

                    <i class="bi bi-file-earmark-excel"></i>
                    Export Excel

                </a>

            </div>

        </div>

    </div>

</div>

<div class="app-card mb-3">

    <div class="card-header">

        <h5 class="card-title">

            <i class="bi bi-file-earmark-excel"></i>
            Import Salary Excel

        </h5>

    </div>

    <div class="card-body">

        <form asp-action="ImportExcel"
              method="post"
              enctype="multipart/form-data">

            @Html.AntiForgeryToken()

            <input type="hidden"
                   name="month"
                   value="@selectedMonth" />

            <input type="hidden"
                   name="year"
                   value="@selectedYear" />

            <div class="row g-3 align-items-end">

                <div class="col-md-8">

                    <label class="form-label"
                           for="salaryFile">
                        Upload Final Salary Sheet
                    </label>

                    <input id="salaryFile"
                           type="file"
                           name="file"
                           accept=".xlsx"
                           class="form-control"
                           required />

                </div>

                <div class="col-md-4">

                    <button type="submit"
                            class="btn-app btn-primary-app w-100">

                        <i class="bi bi-upload"></i>
                        Import Salary

                    </button>

                </div>

            </div>

        </form>

    </div>

</div>

<div class="app-card table-card">

    <div class="card-header">

        <h5 class="card-title">
            Salary Register -
            @(new DateTime(2000, selectedMonth, 1).ToString("MMMM"))
            @selectedYear
        </h5>

    </div>

    <div class="card-body">

        @if (!Model.Items.Any())
        {
            <div class="empty-state">

                <i class="bi bi-cash-stack"></i>

                <p class="mb-0">
                    @ViewBag.EmptyMessage
                </p>


            </div>
        }
        else
        {
            <div class="table-responsive">

                <table class="app-table">

                    <thead>

                        <tr>
                            <th>Employee</th>
                            <th>Actual Salary</th>
                            <th>Pay Days</th>
                            <th>Gross Salary</th>
                            <th>Deductions</th>
                            <th>Net Salary</th>
                            <th>CTC</th>
                            <th>Status</th>
                            <th>Paid On</th>
                            <th class="text-end">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var salary in Model.Items)
                        {
                            <tr>

                                <td>

                                    <strong>
                                        @(salary.Employee?.FullName ?? "-")
                                    </strong>

                                    <br />

                                    <small>
                                        @(salary.Employee?.EmployeeCode ?? "-")
                                    </small>

                                </td>

                                <td>
                                    ₹ @salary.ActualSalary.ToString("N2")
                                </td>

                                <td>
                                    @salary.PayDays.ToString("N2")
                                </td>

                                <td>
                                    ₹ @salary.GrossSalary.ToString("N2")
                                </td>

                                <td>
                                    ₹ @salary.TotalDeductions.ToString("N2")
                                </td>

                                <td>

                                    <strong>
                                        ₹ @salary.NetSalary.ToString("N2")
                                    </strong>

                                </td>

                                <td>
                                    ₹ @salary.CTC.ToString("N2")
                                </td>

                                <td>

                                    @if (salary.PaymentStatus == "Paid")
                                    {
                                        <span class="badge-success">
                                            Paid
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-warning">
                                            Pending
                                        </span>
                                    }

                                </td>

                                <td>
                                    @(salary.PaidOn?.ToString("dd-MMM-yyyy")
                                      ?? "-")
                                </td>

                                <td>

                                    <div class="table-actions justify-content-end">

                                        <a asp-action="Details"
                                           asp-route-id="@salary.Id"
                                           class="btn-app btn-primary-app btn-icon"
                                           title="View salary details"
                                           aria-label="View salary details">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <a asp-action="Payslip"
                                           asp-route-id="@salary.Id"
                                           class="btn-app btn-outline-app btn-icon"
                                           title="View payslip"
                                           aria-label="View payslip">

                                            <i class="bi bi-receipt"></i>

                                        </a>

                                        @if (salary.PaymentStatus != "Paid")
                                        {
                                            <form asp-action="MarkPaid"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <input type="hidden"
                                                       name="id"
                                                       value="@salary.Id" />

                                                <input type="hidden"
                                                       name="month"
                                                       value="@selectedMonth" />

                                                <input type="hidden"
                                                       name="year"
                                                       value="@selectedYear" />

                                                <input type="hidden"
                                                       name="page"
                                                       value="@Model.Pagination.CurrentPage" />

                                                <button type="submit"
                                                        class="btn-app btn-success-app btn-icon"
                                                        title="Mark as paid"
                                                        aria-label="Mark salary as paid"
                                                        onclick="return confirm('Mark this salary as paid?');">

                                                    <i class="bi bi-check-circle"></i>

                                                </button>

                                            </form>
                                        }

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>
        }

        <partial name="_Pagination"
                 model="Model.Pagination" />

    </div>

</div>